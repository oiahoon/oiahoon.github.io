---
import { getCollection } from 'astro:content';
import SpotlightLayout from '../../layouts/SpotlightLayout.astro';
import UiIcon from '../../components/UiIcon.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tagCounts = new Map();
posts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

const sortedTags = Array.from(tagCounts.entries()).sort(([, a], [, b]) => b - a);
const maxCount = Math.max(...sortedTags.map(([, count]) => count), 1);

function getWeight(count: number) {
  const ratio = count / maxCount;
  if (ratio >= 0.75) return 'xl';
  if (ratio >= 0.45) return 'lg';
  if (ratio >= 0.2) return 'md';
  return 'sm';
}

function getTagTransitionName(tag: string) {
  return `tag-label-${encodeURIComponent(tag)}`;
}
---

<SpotlightLayout title="标签 | Joey's Notes" description="按标签浏览文章，快速找到感兴趣的技术主题和内容分类。" lang="zh">
  <section class="section-gap">
    <div class="shell">
      <div class="hero-intro">
        <p class="eyebrow section-kicker"><UiIcon name="tag" size={14} /> <span>Tags</span></p>
        <h1 class="mt-4 text-4xl font-semibold">文章标签</h1>
        <p class="mt-4 muted">共 {sortedTags.length} 个标签，{posts.length} 篇文章。</p>
      </div>

      <div class="tag-cloud mt-12">
        {sortedTags.map(([tag, count]) => (
          <a
            href={`/tags/${encodeURIComponent(tag)}/`}
            class={`tag-cloud__pill tag-cloud__pill--${getWeight(count)}`}
            data-astro-prefetch
            style={`view-transition-name: ${getTagTransitionName(tag)};`}
          >
            <UiIcon name="tag" size={14} class="tag-cloud__icon" />
            <span class="tag-cloud__name">#{tag}</span>
            <span class="tag-cloud__count">{count}</span>
          </a>
        ))}
      </div>

    </div>
  </section>
</SpotlightLayout>

<style>
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 1.1rem;
    width: min(72rem, 100%);
    margin-inline: auto;
  }

  .tag-cloud__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    border: 1px solid color-mix(in srgb, var(--line) 84%, rgba(184, 95, 40, 0.16));
    border-radius: 9999px;
    background:
      radial-gradient(circle at top left, rgba(184, 95, 40, 0.08), transparent 55%),
      color-mix(in srgb, var(--surface) 96%, transparent);
    box-shadow: 0 10px 28px rgba(15, 23, 32, 0.06);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .tag-cloud__pill:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 60%, var(--line));
    box-shadow: 0 14px 34px rgba(15, 23, 32, 0.1);
  }

  :global(.tag-cloud__icon) {
    color: color-mix(in srgb, var(--accent) 64%, var(--muted));
    opacity: 0.62;
  }

  .tag-cloud__pill--xl {
    padding: 1rem 1.4rem;
    font-size: 1.55rem;
  }

  .tag-cloud__pill--lg {
    padding: 0.9rem 1.25rem;
    font-size: 1.28rem;
  }

  .tag-cloud__pill--md {
    padding: 0.8rem 1.1rem;
    font-size: 1.06rem;
  }

  .tag-cloud__pill--sm {
    padding: 0.72rem 0.95rem;
    font-size: 0.94rem;
    opacity: 0.88;
  }

  .tag-cloud__name {
    font-weight: 600;
    line-height: 1;
    color: var(--text);
  }

  .tag-cloud__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 2rem;
    padding-inline: 0.5rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--line) 72%, transparent);
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
  }
</style>
