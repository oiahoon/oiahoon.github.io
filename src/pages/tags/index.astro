---
import { getCollection } from 'astro:content';
import SpotlightLayout from '../../layouts/SpotlightLayout.astro';
import UiIcon from '../../components/UiIcon.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tagCounts = new Map<string, number>();
posts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

const sortedTags = Array.from(tagCounts.entries()).sort(([tagA, countA], [tagB, countB]) => {
  return countB - countA || tagA.localeCompare(tagB, 'zh-CN');
});
const maxCount = Math.max(...sortedTags.map(([, count]) => count), 1);
const totalLinks = sortedTags.reduce((total, [, count]) => total + count, 0);

function getWeight(count: number) {
  const ratio = count / maxCount;
  if (ratio >= 0.75) return 'xl';
  if (ratio >= 0.45) return 'lg';
  if (ratio >= 0.2) return 'md';
  return 'sm';
}

function getTagTransitionName(tag: string) {
  let hash = 0;
  for (let index = 0; index < tag.length; index += 1) {
    hash = ((hash << 5) - hash + tag.charCodeAt(index)) | 0;
  }
  return `tag-label-${Math.abs(hash).toString(36)}`;
}
---

<SpotlightLayout title="Tags | Joey's Notes" description="按标签浏览摄影作品、生活记录与早年工程笔记。" lang="zh">
  <section class="section-gap tags-page">
    <div class="shell">
      <div class="hero-intro tags-hero">
        <p class="eyebrow tags-kicker"><UiIcon name="tag" size={14} /> <span>Tags</span></p>
        <h1 class="tags-title">Browse by tag.</h1>
        <p class="tags-lede">按主题浏览摄影作品、生活记录与早年工程笔记。</p>

        <dl class="tags-summary" aria-label="标签归档概览">
          <div>
            <dt>Tags</dt>
            <dd>{sortedTags.length}</dd>
          </div>
          <div>
            <dt>Posts</dt>
            <dd>{posts.length}</dd>
          </div>
          <div>
            <dt>Uses</dt>
            <dd>{totalLinks}</dd>
          </div>
        </dl>
      </div>

      <div class="tag-index" aria-label="所有标签">
        {sortedTags.map(([tag, count]) => (
          <a
            href={`/tags/${encodeURIComponent(tag)}/`}
            class={`tag-index__item tag-index__item--${getWeight(count)}`}
            data-astro-prefetch
            style={`view-transition-name: ${getTagTransitionName(tag)};`}
            aria-label={`浏览 ${tag} 标签，共 ${count} 篇内容`}
          >
            <span class="tag-index__main">
              <UiIcon name="tag" size={13} class="tag-index__icon" />
              <span class="tag-index__name">#{tag}</span>
            </span>
            <span class="tag-index__meta">
              <span class="tag-index__bar" aria-hidden="true"><span style={`--tag-weight: ${count / maxCount};`}></span></span>
              <span class="tag-index__count">{count}</span>
            </span>
          </a>
        ))}
      </div>

    </div>
  </section>
</SpotlightLayout>

<style>
  .tags-page {
    margin-top: clamp(2.8rem, 6vw, 5.2rem);
  }

  .tags-hero {
    width: min(56rem, 100%);
  }

  .tags-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
  }

  .tags-kicker :global(.ui-icon) {
    color: color-mix(in srgb, var(--accent) 54%, var(--muted));
    opacity: 0.62;
  }

  .tags-title {
    margin-top: 1rem;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 0.98;
    font-weight: 600;
  }

  .tags-lede {
    width: min(38rem, 100%);
    margin: 1.05rem auto 0;
    color: color-mix(in srgb, var(--muted) 88%, var(--text));
    font-size: clamp(0.98rem, 2.2vw, 1.08rem);
    line-height: 1.8;
  }

  .tags-summary {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.15rem 2.2rem;
    margin-top: 1.8rem;
    color: var(--muted);
  }

  .tags-summary div {
    display: grid;
    min-width: 4.2rem;
    gap: 0.12rem;
    text-align: center;
  }

  .tags-summary dt {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .tags-summary dd {
    margin: 0;
    color: var(--text);
    font-family: var(--font-serif);
    font-size: 1.72rem;
    line-height: 1;
  }

  .tag-index {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(1.6rem, 4vw, 3.2rem);
    width: min(64rem, 100%);
    margin-top: clamp(2.2rem, 5vw, 3.4rem);
    margin-inline: auto;
    border-top: 1px solid var(--line);
  }

  .tag-index__item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    min-height: 4.25rem;
    border-bottom: 1px solid var(--line);
    color: inherit;
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard);
  }

  .tag-index__item:hover,
  .tag-index__item:focus-visible {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
  }

  .tag-index__main {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    gap: 0.52rem;
  }

  :global(.tag-index__icon) {
    color: color-mix(in srgb, var(--accent) 58%, var(--muted));
    opacity: 0.64;
  }

  .tag-index__name {
    min-width: 0;
    overflow-wrap: anywhere;
    color: var(--text);
    font-weight: 600;
    line-height: 1.25;
  }

  .tag-index__item:hover .tag-index__name,
  .tag-index__item:focus-visible .tag-index__name {
    color: inherit;
  }

  .tag-index__item--xl .tag-index__name {
    font-size: clamp(1.3rem, 2.5vw, 1.72rem);
  }

  .tag-index__item--lg .tag-index__name {
    font-size: clamp(1.12rem, 2vw, 1.38rem);
  }

  .tag-index__item--md .tag-index__name {
    font-size: 1.06rem;
  }

  .tag-index__item--sm .tag-index__name {
    font-size: 0.98rem;
  }

  .tag-index__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--muted);
  }

  .tag-index__bar {
    display: block;
    width: clamp(2.4rem, 7vw, 4.6rem);
    height: 1px;
    background: color-mix(in srgb, var(--line) 84%, transparent);
  }

  .tag-index__bar span {
    display: block;
    width: calc(var(--tag-weight) * 100%);
    height: 100%;
    background: color-mix(in srgb, var(--accent) 58%, var(--line));
  }

  .tag-index__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.8rem;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  @media (max-width: 720px) {
    .tags-page {
      margin-top: 2.35rem;
    }

    .tags-title {
      margin-top: 0.8rem;
      font-size: clamp(2.45rem, 13vw, 3.8rem);
    }

    .tags-lede {
      margin-top: 0.85rem;
      font-size: 0.98rem;
      line-height: 1.7;
    }

    .tags-summary {
      gap: 0.9rem 1.4rem;
      margin-top: 1.35rem;
    }

    .tags-summary dd {
      font-size: 1.45rem;
    }

    .tag-index {
      grid-template-columns: 1fr;
      margin-top: 2rem;
    }

    .tag-index__item {
      min-height: 3.8rem;
    }

    .tag-index__bar {
      width: 2.7rem;
    }
  }
</style>
