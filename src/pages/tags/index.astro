---
import { getCollection } from 'astro:content';
import SpotlightLayout from '../../layouts/SpotlightLayout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tagCounts = new Map();
posts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

const sortedTags = Array.from(tagCounts.entries()).sort(([, a], [, b]) => b - a);
const rows = [0, 1, 2].map((index) => sortedTags.filter((_, tagIndex) => tagIndex % 3 === index));
---

<SpotlightLayout title="标签 | Joey's Notes" description="按标签浏览文章，快速找到感兴趣的技术主题和内容分类。" lang="zh">
  <section class="section-gap">
    <div class="shell">
      <div class="hero-intro">
        <p class="eyebrow">Tags</p>
        <h1 class="mt-4 text-4xl font-semibold">文章标签</h1>
        <p class="mt-4 muted">共 {sortedTags.length} 个标签，{posts.length} 篇文章。</p>
      </div>

      <div class="tag-cloud-stage mx-auto mt-12 max-w-5xl">
        <div class="tag-cloud-shell">
          {rows.map((row, rowIndex) => (
            <div class={`tag-cloud-lane ${rowIndex % 2 === 1 ? 'is-reverse' : ''}`}>
              <div class="tag-cloud-track">
                {row.map(([tag, count]) => (
                  <a
                    href={`/tags/${tag}/`}
                    class="tag-cloud-pill"
                    style={`--tag-scale:${Math.min(1.14, 0.92 + count / 14)};`}
                  >
                    <span class="tag-cloud-name">#{tag}</span>
                    <span class="tag-cloud-count">{count}</span>
                  </a>
                ))}
              </div>

              <div class="tag-cloud-track" aria-hidden="true">
                {row.map(([tag, count]) => (
                  <a
                    href={`/tags/${tag}/`}
                    class="tag-cloud-pill"
                    tabindex="-1"
                    style={`--tag-scale:${Math.min(1.14, 0.92 + count / 14)};`}
                  >
                    <span class="tag-cloud-name">#{tag}</span>
                    <span class="tag-cloud-count">{count}</span>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mx-auto mt-12 max-w-5xl">
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {sortedTags.map(([tag, count]) => (
            <a href={`/tags/${tag}/`} class="soft-panel group flex items-center justify-between px-4 py-3 transition hover:border-[var(--accent)]">
              <span class="text-sm font-medium">#{tag}</span>
              <span class="text-xs muted">{count} 篇</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</SpotlightLayout>

<style>
  .tag-cloud-stage {
    position: relative;
    padding: 1.25rem 0;
  }

  .tag-cloud-stage::before,
  .tag-cloud-stage::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 4rem;
    z-index: 2;
    pointer-events: none;
  }

  .tag-cloud-stage::before {
    left: 0;
    background: linear-gradient(90deg, var(--bg), transparent);
  }

  .tag-cloud-stage::after {
    right: 0;
    background: linear-gradient(270deg, var(--bg), transparent);
  }

  .tag-cloud-shell {
    display: grid;
    gap: 1rem;
  }

  .tag-cloud-lane {
    display: flex;
    width: max-content;
    min-width: 100%;
    gap: 0.9rem;
    animation: tag-cloud-scroll 34s linear infinite;
    will-change: transform;
  }

  .tag-cloud-lane.is-reverse {
    animation-direction: reverse;
    animation-duration: 42s;
  }

  .tag-cloud-lane:hover {
    animation-play-state: paused;
  }

  .tag-cloud-track {
    display: flex;
    flex: none;
    gap: 0.9rem;
    padding-right: 0.9rem;
  }

  .tag-cloud-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    white-space: nowrap;
    border: 1px solid var(--line);
    border-radius: 9999px;
    padding: 0.85rem 1.15rem;
    background:
      radial-gradient(circle at top left, rgba(184, 95, 40, 0.12), transparent 55%),
      color-mix(in srgb, var(--surface) 94%, transparent);
    box-shadow: 0 10px 30px rgba(15, 23, 32, 0.06);
    transform: scale(var(--tag-scale, 1));
    transform-origin: center;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .tag-cloud-pill:hover {
    transform: scale(calc(var(--tag-scale, 1) + 0.04));
    border-color: color-mix(in srgb, var(--accent) 65%, var(--line));
    box-shadow: 0 14px 35px rgba(15, 23, 32, 0.1);
  }

  .tag-cloud-name {
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--text);
  }

  .tag-cloud-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.9rem;
    height: 1.9rem;
    padding-inline: 0.45rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--line) 72%, transparent);
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 600;
  }

  @keyframes tag-cloud-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(calc(-50% - 0.45rem));
    }
  }

  @media (max-width: 640px) {
    .tag-cloud-stage::before,
    .tag-cloud-stage::after {
      width: 1.25rem;
    }

    .tag-cloud-pill {
      padding: 0.72rem 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-cloud-lane {
      animation: none;
      width: 100%;
      min-width: 0;
      overflow-x: auto;
      padding-bottom: 0.25rem;
      scrollbar-width: none;
    }

    .tag-cloud-lane::-webkit-scrollbar {
      display: none;
    }
  }
</style>
