---
import { getCollection } from 'astro:content';
import SpotlightLayout from '../../layouts/SpotlightLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

  const POSTS_PER_PAGE = 6;
  const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
    props: {
      posts: sortedPosts,
      currentPage: i + 1,
      totalPages,
      POSTS_PER_PAGE,
    },
  }));
}

const { posts, currentPage, totalPages, POSTS_PER_PAGE } = Astro.props;
const startIndex = (currentPage - 1) * POSTS_PER_PAGE;
const endIndex = startIndex + POSTS_PER_PAGE;
const currentPosts = posts.slice(startIndex, endIndex);

const visiblePageNumbers = Array.from(
  new Set([1, currentPage - 1, currentPage, currentPage + 1, totalPages].filter((page) => page >= 1 && page <= totalPages)),
).sort((a, b) => a - b);

const compactPages = visiblePageNumbers.flatMap((page, index) => {
  const previous = visiblePageNumbers[index - 1];
  return index > 0 && previous && page - previous > 1 ? [`gap-${previous}-${page}`, page] : [page];
});
---

<SpotlightLayout title={`文章 | 第${currentPage}页`} description="随便聊聊的分页归档" lang="zh">
  <section class="section-gap">
    <div class="shell">
      <div class="hero-intro">
        <p class="eyebrow">Articles</p>
        <h1 class="mt-4 text-4xl font-semibold">随便聊聊 · 第 {currentPage} 页</h1>
      </div>

      <div class="entry-stream archive-stream mt-10">
        {currentPosts.map((post) => (
          <article class="entry-item">
            <time class="entry-meta skeleton-text" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="entry-title skeleton-text">
              <a href={`/posts/${post.id}/`} data-astro-prefetch style={`view-transition-name: article-title-${post.id};`}>
                {post.data.title}
              </a>
            </h2>
            <p class="entry-desc skeleton-text">{post.data.description || post.data.subtitle || '点击查看完整内容。'}</p>
          </article>
        ))}
      </div>

      <nav class="pager archive-pager" aria-label="分页归档">
        {currentPage > 1 && (
          <a href={currentPage === 2 ? '/' : `/page/${currentPage - 1}/`} class="pager-link archive-pager__link" data-astro-prefetch>
            上一页
          </a>
        )}

        {compactPages.map((item) => {
          if (typeof item === 'string') {
            return <span class="archive-pager__gap" aria-hidden="true">…</span>;
          }

          return (
            <a
              href={item === 1 ? '/' : `/page/${item}/`}
              class={`pager-link archive-pager__link ${item === currentPage ? 'current' : ''}`}
              aria-current={item === currentPage ? 'page' : undefined}
              data-astro-prefetch
            >
              {item}
            </a>
          );
        })}

        {currentPage < totalPages && (
          <a href={`/page/${currentPage + 1}/`} class="pager-link archive-pager__link" data-astro-prefetch>
            下一页
          </a>
        )}
      </nav>
    </div>
  </section>
</SpotlightLayout>

<style>
  .archive-pager {
    gap: 0.45rem;
  }

  .archive-stream .entry-title a {
    display: inline-flex;
    min-height: 2rem;
    align-items: center;
  }

  .archive-pager__gap {
    display: inline-flex;
    min-width: 2.1rem;
    min-height: 2.3rem;
    align-items: center;
    justify-content: center;
    color: var(--muted);
  }

  .archive-pager__link {
    min-width: 2.3rem;
  }

  @media (max-width: 560px) {
    .archive-pager {
      justify-content: flex-start;
      gap: 0.38rem;
    }

    .archive-pager__link {
      min-width: 2.2rem;
      min-height: 2.45rem;
      padding-inline: 0.78rem;
    }

    .archive-pager__gap {
      min-width: 1.4rem;
      min-height: 2.45rem;
    }
  }
</style>
