---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const photographyPosts = (await getCollection('posts', ({ data }) => !data.draft && data.type === 'photography'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const currentPhotoIndex = photographyPosts.findIndex((item) => item.id === post.id);
const previousPhoto = currentPhotoIndex > 0 ? photographyPosts[currentPhotoIndex - 1] : null;
const nextPhoto = currentPhotoIndex >= 0 && currentPhotoIndex < photographyPosts.length - 1
  ? photographyPosts[currentPhotoIndex + 1]
  : null;
const photoCollection = post.data.type === 'photography'
  ? photographyPosts.map((item) => ({
      slug: item.id,
      title: item.data.title,
      date: item.data.date,
      image: item.data.header_img || item.data.gallery?.[0]?.src,
      active: item.id === post.id,
    }))
  : undefined;
const { Content } = await render(post);
---

<PostLayout
  {...post.data}
  slug={post.id}
  previousPhoto={previousPhoto ? {
    slug: previousPhoto.id,
    title: previousPhoto.data.title,
    date: previousPhoto.data.date,
    image: previousPhoto.data.header_img || previousPhoto.data.gallery?.[0]?.src,
  } : undefined}
  nextPhoto={nextPhoto ? {
    slug: nextPhoto.id,
    title: nextPhoto.data.title,
    date: nextPhoto.data.date,
    image: nextPhoto.data.header_img || nextPhoto.data.gallery?.[0]?.src,
  } : undefined}
  photoCollection={photoCollection}
>
  <Content />
</PostLayout>
