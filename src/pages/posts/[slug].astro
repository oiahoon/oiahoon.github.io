---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const photographyPosts = (await getCollection('posts', ({ data }) => !data.draft && data.type === 'photography'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const currentPhotoIndex = photographyPosts.findIndex((item) => item.slug === post.slug);
const previousPhoto = currentPhotoIndex > 0 ? photographyPosts[currentPhotoIndex - 1] : null;
const nextPhoto = currentPhotoIndex >= 0 && currentPhotoIndex < photographyPosts.length - 1
  ? photographyPosts[currentPhotoIndex + 1]
  : null;
const { Content } = await post.render();
---

<PostLayout
  {...post.data}
  slug={post.slug}
  previousPhoto={previousPhoto ? {
    slug: previousPhoto.slug,
    title: previousPhoto.data.title,
    date: previousPhoto.data.date,
    image: previousPhoto.data.header_img || previousPhoto.data.gallery?.[0]?.src,
  } : undefined}
  nextPhoto={nextPhoto ? {
    slug: nextPhoto.slug,
    title: nextPhoto.data.title,
    date: nextPhoto.data.date,
    image: nextPhoto.data.header_img || nextPhoto.data.gallery?.[0]?.src,
  } : undefined}
>
  <Content />
</PostLayout>
