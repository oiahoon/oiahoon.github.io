---
import UiIcon from '../components/UiIcon.astro';
import SpotlightLayout from '../layouts/SpotlightLayout.astro';

const projects = [
  {
    title: 'Running Page 2.0',
    href: 'https://run2.miaowu.org/dashboard',
    label: '跑步数据面板',
    description: '把跑步记录整理成一个可浏览的表现面板，偏个人工具，也给训练状态留一点秩序。',
    meta: 'run2.miaowu.org/dashboard',
    icon: 'compass',
  },
  {
    title: '朕的一生',
    href: 'https://game.miaowu.org/',
    label: '文字叙事游戏',
    description: '一个轻量的网页小游戏，用选择、事件和一点随机性推进一段人生叙事。',
    meta: 'game.miaowu.org',
    icon: 'spark',
  },
] as const;
---

<SpotlightLayout
  title="作品集 | Joey's Notes"
  description="黄药师的个人项目展示"
>
  <div class="portfolio-page">
    <div class="shell portfolio-shell">
      <div class="portfolio-content">
        <header class="portfolio-hero">
          <p class="portfolio-kicker">Portfolio</p>
          <h1>
            一些还在运行的小项目
          </h1>
          <p>
            不算正式作品集，更像把自己做过、还愿意留在外面的东西放在一起。跑步数据、一个网页游戏，以及这个站点本身。
          </p>
        </header>

        <section class="portfolio-section" aria-labelledby="live-projects-heading">
          <h2 id="live-projects-heading" class="portfolio-section__title">
            小项目
          </h2>
          <div class="portfolio-projects">
            {projects.map((project) => (
              <a
                href={project.href}
                target="_blank"
                rel="noopener noreferrer"
                class="portfolio-project"
              >
                <div class="portfolio-project__head">
                  <div class="portfolio-project__label">
                    <span class="portfolio-project__icon">
                      <UiIcon name={project.icon} size={15} />
                    </span>
                    <p>{project.label}</p>
                  </div>
                  <span class="portfolio-project__arrow" aria-hidden="true">↗</span>
                </div>

                <h3>{project.title}</h3>
                <p class="portfolio-project__copy">
                  {project.description}
                </p>
                <p class="portfolio-project__meta">{project.meta}</p>
              </a>
            ))}
          </div>
        </section>

        <section class="portfolio-site" aria-labelledby="site-project-heading">
          <div class="portfolio-site__grid">
            <div>
              <h2 id="site-project-heading">
                <UiIcon name="notebook" size={16} class="portfolio-site__icon" />
                <span>Joey's Notes</span>
              </h2>
              <p>
                当前这个站点也是一个持续整理中的项目。它从早年的技术博客慢慢变成了文字、摄影和一些个人实验的入口。
              </p>
            </div>

            <div class="portfolio-site__links">
              <a href="/photography/" data-astro-prefetch>
                Photographs
              </a>
              <a href="/articles/" data-astro-prefetch>
                Notes
              </a>
              <a href="https://github.com/oiahoon/oiahoon.github.io" target="_blank" rel="noopener noreferrer">
                GitHub
              </a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</SpotlightLayout>

<style>
  .portfolio-page {
    margin-top: clamp(3.5rem, 8vw, 7rem);
  }

  .portfolio-shell {
    max-width: 72rem;
  }

  .portfolio-content {
    width: min(100%, 64rem);
    margin-inline: auto;
  }

  .portfolio-hero {
    max-width: 42rem;
  }

  .portfolio-kicker {
    margin: 0;
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 560;
  }

  .portfolio-hero h1 {
    margin: 1rem 0 0;
    color: var(--text);
    font-size: clamp(2.55rem, 6vw, 3.4rem);
    line-height: 1.08;
    font-weight: 680;
    letter-spacing: 0;
  }

  .portfolio-hero p {
    margin: 1.35rem 0 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.9;
  }

  .portfolio-section {
    margin-top: clamp(3rem, 6vw, 4rem);
  }

  .portfolio-section__title {
    margin: 0;
    color: var(--text);
    font-size: 0.98rem;
    font-weight: 620;
  }

  .portfolio-projects {
    display: grid;
    gap: 1rem;
    margin-top: 1.35rem;
  }

  .portfolio-project {
    display: block;
    min-height: 16.5rem;
    border: 1px solid color-mix(in srgb, var(--line) 78%, transparent);
    border-radius: 8px;
    padding: 1.45rem;
    background: color-mix(in srgb, var(--surface) 68%, transparent);
    color: inherit;
    text-decoration: none;
    transition:
      background var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  .portfolio-project:hover,
  .portfolio-project:focus-visible {
    border-color: color-mix(in srgb, var(--accent) 32%, var(--line));
    background: color-mix(in srgb, var(--accent) 6%, var(--surface));
    transform: translateY(-1px);
  }

  .portfolio-project__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .portfolio-project__label {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    gap: 0.75rem;
  }

  .portfolio-project__label p,
  .portfolio-project__meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 560;
  }

  .portfolio-project__icon {
    display: inline-flex;
    width: 2.25rem;
    height: 2.25rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--line) 82%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--bg) 84%, var(--surface));
    color: color-mix(in srgb, var(--accent) 52%, var(--muted));
  }

  .portfolio-project__arrow {
    color: color-mix(in srgb, var(--muted) 54%, transparent);
    font-size: 0.92rem;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .portfolio-project:hover .portfolio-project__arrow,
  .portfolio-project:focus-visible .portfolio-project__arrow {
    color: var(--accent);
  }

  .portfolio-project h3 {
    margin: 1.5rem 0 0;
    color: var(--text);
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 650;
  }

  .portfolio-project__copy {
    margin: 0.8rem 0 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.8;
  }

  .portfolio-project__meta {
    margin-top: 1.5rem;
    color: color-mix(in srgb, var(--muted) 78%, transparent);
  }

  .portfolio-site {
    margin-top: clamp(2.8rem, 6vw, 4rem);
    border-top: 1px solid var(--line);
    padding-top: 2.5rem;
  }

  .portfolio-site__grid {
    display: grid;
    gap: 2rem;
  }

  .portfolio-site h2 {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0;
    color: var(--text);
    font-size: 0.98rem;
    font-weight: 620;
  }

  :global(.portfolio-site__icon) {
    color: color-mix(in srgb, var(--accent) 48%, var(--muted));
  }

  .portfolio-site p {
    max-width: 42rem;
    margin: 1rem 0 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.85;
  }

  .portfolio-site__links {
    display: grid;
    gap: 0.85rem;
    font-size: 0.94rem;
  }

  .portfolio-site__links a {
    display: inline-flex;
    min-height: 2rem;
    align-items: center;
    color: var(--muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .portfolio-site__links a:hover,
  .portfolio-site__links a:focus-visible {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 0.3em;
  }

  .portfolio-site__links a:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 55%, transparent);
    outline-offset: 3px;
  }

  @media (min-width: 640px) {
    .portfolio-projects {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 960px) {
    .portfolio-site__grid {
      grid-template-columns: minmax(0, 1fr) 18rem;
    }
  }

  @media (max-width: 640px) {
    .portfolio-page {
      margin-top: 2.75rem;
    }

    .portfolio-project {
      min-height: 0;
      padding: 1.35rem;
    }
  }
</style>
