---
import UiIcon from '../components/UiIcon.astro';
import SpotlightLayout from '../layouts/SpotlightLayout.astro';

const projects = [
  {
    title: 'Running Page 2.0',
    href: 'https://run2.miaowu.org/dashboard',
    label: '跑步数据面板',
    description: '把跑步记录整理成一个可浏览的表现面板，偏个人工具，也给训练状态留一点秩序。',
    meta: 'run2.miaowu.org/dashboard',
    icon: 'compass',
  },
  {
    title: '朕的一生',
    href: 'https://game.miaowu.org/',
    label: '文字叙事游戏',
    description: '一个轻量的网页小游戏，用选择、事件和一点随机性推进一段人生叙事。',
    meta: 'game.miaowu.org',
    icon: 'spark',
  },
] as const;
---

<SpotlightLayout
  title="作品集 | Joey's Notes"
  description="黄药师的个人项目展示"
>
  <div class="mt-16 sm:px-8 lg:mt-28">
    <div class="mx-auto w-full max-w-7xl lg:px-8">
      <div class="relative px-4 sm:px-8 lg:px-12">
        <div class="mx-auto max-w-2xl lg:max-w-5xl">
          <header class="max-w-2xl">
            <p class="text-sm font-medium text-zinc-500 dark:text-zinc-400">Portfolio</p>
            <h1 class="mt-4 text-4xl font-bold text-zinc-800 sm:text-5xl dark:text-zinc-100">
              一些还在运行的小项目
            </h1>
            <p class="mt-6 text-base leading-7 text-zinc-600 dark:text-zinc-400">
              不算正式作品集，更像把自己做过、还愿意留在外面的东西放在一起。跑步数据、一个网页游戏，以及这个站点本身。
            </p>
          </header>

          <section class="mt-14 sm:mt-16" aria-labelledby="live-projects-heading">
            <h2 id="live-projects-heading" class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">
              小项目
            </h2>
            <div class="mt-6 grid gap-5 sm:grid-cols-2">
              {projects.map((project) => (
                <a
                  href={project.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block rounded-lg border border-zinc-100 p-6 transition hover:border-zinc-200 hover:bg-zinc-50/60 dark:border-zinc-700/40 dark:hover:border-zinc-600/70 dark:hover:bg-zinc-800/30"
                >
                  <div class="flex items-start justify-between gap-5">
                    <div class="flex items-center gap-3">
                      <span class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-zinc-400 shadow-sm shadow-zinc-800/5 ring-1 ring-zinc-900/5 dark:bg-zinc-800 dark:text-zinc-500 dark:ring-zinc-700/60">
                        <UiIcon name={project.icon} size={15} />
                      </span>
                      <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400">{project.label}</p>
                    </div>
                    <span class="text-sm text-zinc-300 transition group-hover:text-orange-500 dark:text-zinc-500" aria-hidden="true">↗</span>
                  </div>

                  <h3 class="mt-6 text-xl font-semibold text-zinc-800 dark:text-zinc-100">{project.title}</h3>
                  <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
                    {project.description}
                  </p>
                  <p class="mt-6 text-xs font-medium text-zinc-400 dark:text-zinc-500">{project.meta}</p>
                </a>
              ))}
            </div>
          </section>

          <section class="mt-12 border-t border-zinc-100 pt-10 dark:border-zinc-700/40 sm:mt-16" aria-labelledby="site-project-heading">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_18rem]">
              <div>
                <h2 id="site-project-heading" class="flex items-center text-sm font-semibold text-zinc-900 dark:text-zinc-100">
                  <UiIcon name="notebook" size={16} class="text-zinc-400 dark:text-zinc-500" />
                  <span class="ml-3">Joey's Notes</span>
                </h2>
                <p class="mt-4 max-w-2xl text-sm leading-6 text-zinc-600 dark:text-zinc-400">
                  当前这个站点也是一个持续整理中的项目。它从早年的技术博客慢慢变成了文字、摄影和一些个人实验的入口。
                </p>
              </div>

              <div class="flex flex-col gap-3 text-sm">
                <a href="/photography/" class="text-zinc-500 transition hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100" data-astro-prefetch>
                  Photographs
                </a>
                <a href="/articles/" class="text-zinc-500 transition hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100" data-astro-prefetch>
                  Notes
                </a>
                <a href="https://github.com/oiahoon/oiahoon.github.io" target="_blank" rel="noopener noreferrer" class="text-zinc-500 transition hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100">
                  GitHub
                </a>
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
</SpotlightLayout>
