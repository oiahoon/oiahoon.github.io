---
import { getCollection } from 'astro:content';
import SpotlightLayout from '../layouts/SpotlightLayout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft && data.type !== 'photography');
const sorted = [...posts].sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const tagCounts = new Map<string, number>();
const excludedTopicTags = new Set(['Notes']);
posts.forEach((post) => {
  post.data.tags
    ?.filter((tag): tag is string => typeof tag === 'string' && tag.trim().length > 0)
    .forEach((tag) => {
      const normalized = tag.trim();
      if (excludedTopicTags.has(normalized)) return;
      tagCounts.set(normalized, (tagCounts.get(normalized) || 0) + 1);
    });
});

const topTags = Array.from(tagCounts.entries())
  .sort(([tagA, countA], [tagB, countB]) => countB - countA || tagA.localeCompare(tagB, 'zh-CN'))
  .slice(0, 8);

const shouldShowTopicLinks = topTags.length >= 3;
---

<SpotlightLayout title="Legacy Notes Archive | Joey's Notes" description="早年的工程实践、工具折腾和技术笔记，作为长期 archive 保留。" lang="zh">
  <section class="section-gap articles-page">
    <div class="shell">
      <div class="hero-intro articles-hero">
        <p class="eyebrow articles-kicker">Legacy Notes Archive</p>
        <h1 class="articles-title">Engineering notes kept for reference.</h1>
        <p class="articles-lede">一些早年的 Rails、Docker、macOS、工具折腾与工程实践笔记。内容不再作为活跃博客维护，但仍作为长期 archive 保存。</p>

        {shouldShowTopicLinks && (
          <nav class="articles-topic-links" aria-label="高频文章标签">
            {topTags.map(([tag, count]) => (
              <a
                href={`/tags/${encodeURIComponent(tag)}/`}
                class="articles-topic-link"
                aria-label={`浏览 ${tag} 标签，共 ${count} 篇文章`}
                data-astro-prefetch
              >
                <span>{tag}</span>
                <span class="articles-topic-count" aria-hidden="true">{count}</span>
              </a>
            ))}
          </nav>
        )}
      </div>

      <div class="entry-stream articles-stream">
        {sorted.map((post) => (
          <article class="entry-item">
            <time class="entry-meta skeleton-text" datetime={post.data.date.toISOString()}>
              <span>{post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).replaceAll('/', '.')}</span>
            </time>
            <h2 class="entry-title skeleton-text articles-entry-title">
              <a href={`/posts/${post.id}/`} data-astro-prefetch style={`view-transition-name: article-title-${post.id};`}>
                {post.data.title}
              </a>
            </h2>
            <p class="entry-desc skeleton-text articles-entry-desc">{post.data.description || post.data.subtitle || '点击查看完整内容。'}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</SpotlightLayout>

<style>
  .articles-page {
    margin-top: clamp(2.8rem, 6vw, 5.2rem);
  }

  .articles-hero {
    width: min(52rem, 100%);
    text-align: left;
  }

  .articles-kicker {
    display: block;
    text-align: left;
  }

  .articles-title {
    margin-top: 1rem;
    font-size: clamp(2.75rem, 5.6vw, 4.4rem);
    line-height: 1.05;
    font-weight: 600;
  }

  .articles-lede {
    width: min(38rem, 100%);
    margin: 1rem 0 0;
    color: color-mix(in srgb, var(--muted) 88%, var(--text));
    font-size: clamp(0.98rem, 2.2vw, 1.08rem);
    line-height: 1.8;
  }

  .articles-topic-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.5rem 1rem;
    margin-top: 1.45rem;
  }

  .articles-topic-link {
    display: inline-flex;
    min-height: 2rem;
    align-items: center;
    gap: 0.38rem;
    padding: 0.1rem 0;
    color: var(--muted);
    background: transparent;
    font-size: 0.9rem;
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .articles-topic-link:hover,
  .articles-topic-link:focus-visible {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 0.35em;
  }

  .articles-topic-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 62%, transparent);
    outline-offset: 3px;
  }

  .articles-topic-count {
    display: inline-flex;
    min-width: 1.25rem;
    height: 1.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: transparent;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .articles-stream {
    margin-top: clamp(2.1rem, 4.5vw, 3rem);
  }

  .articles-entry-title,
  .articles-entry-desc {
    overflow-wrap: anywhere;
  }

  .articles-entry-desc {
    color: color-mix(in srgb, var(--muted) 86%, var(--text));
  }

  @media (max-width: 640px) {
    .articles-page {
      margin-top: 1.75rem;
    }

    .articles-title {
      margin-top: 0.65rem;
      font-size: clamp(2rem, 9.4vw, 2.8rem);
      line-height: 1.08;
    }

    .articles-lede {
      margin-top: 0.72rem;
      font-size: 0.94rem;
      line-height: 1.65;
    }

    .articles-topic-links {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      justify-content: stretch;
      gap: 0.35rem 1rem;
      margin-top: 0.95rem;
    }

    .articles-topic-link {
      min-width: 0;
      min-height: 2.2rem;
      justify-content: space-between;
      border-bottom: 1px solid color-mix(in srgb, var(--line) 72%, transparent);
      padding-block: 0.25rem;
      font-size: 0.88rem;
    }

    .articles-topic-link span:first-child {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .articles-stream {
      margin-top: 1.55rem;
    }
  }
</style>
