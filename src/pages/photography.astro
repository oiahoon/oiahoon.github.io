---
import { getCollection } from 'astro:content';
import SpotlightLayout from '../layouts/SpotlightLayout.astro';
import { getPreviewImage } from '../utils/extractFirstImage';
import ProgressiveImage from '../components/ProgressiveImage.astro';

const photos = await getCollection('posts', ({ data }) => !data.draft && data.type === 'photography');
const sorted = photos.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const featured = sorted[0];
const remaining = sorted.slice(1);
const years = [...new Set(sorted.map((photo) => photo.data.date.getFullYear()))].sort((a, b) => b - a);
const latestYear = years[0];
const earliestYear = years[years.length - 1];
const totalImages = sorted.reduce((sum, photo) => sum + (photo.data.gallery?.length || 1), 0);
const groupedArchive = years.map((year) => ({
  year,
  photos: remaining.filter((photo) => photo.data.date.getFullYear() === year),
})).filter((group) => group.photos.length > 0);
---

<SpotlightLayout title="摄影作品 | Joey's Notes" description="摄影归档" lang="zh">
  <section class="section-gap">
    <div class="shell">
      <div class="photo-index-shell">
        <div class="photo-index-hero">
          <div>
            <p class="eyebrow">Photography</p>
            <h1 class="mt-4 text-4xl font-semibold photo-index-shell__title">摄影作品</h1>
            <p class="photo-index-hero__lede mt-5">
              按时间持续归档街景、旅途和日常观察，让画面本身承担叙事。
            </p>
          </div>

          <div class="photo-index-hero__stats">
            <div>
              <span>作品</span>
              <strong>{sorted.length}</strong>
            </div>
            <div>
              <span>照片</span>
              <strong>{totalImages}</strong>
            </div>
            <div>
              <span>时间</span>
              <strong>{latestYear === earliestYear ? latestYear : `${earliestYear} - ${latestYear}`}</strong>
            </div>
          </div>
        </div>

        {featured && (() => {
          const image = featured.data.gallery?.[0]?.src || getPreviewImage(featured);
          if (!image) return null;
          return (
            <article class="photo-feature mt-12">
              <a href={`/posts/${featured.slug}/`} class="photo-feature__media">
                <ProgressiveImage src={image} alt={featured.data.title || '摄影作品'} class="photo-feature__image" loading="eager" decoding="async" />
              </a>
              <div class="photo-feature__content">
                <p class="photo-feature__meta">
                  {featured.data.date.toLocaleDateString('zh-CN')}
                  {featured.data.location ? ` · ${featured.data.location}` : ''}
                </p>
                <h2 class="photo-feature__title">
                  <a href={`/posts/${featured.slug}/`}>{featured.data.title || '未命名作品'}</a>
                </h2>
                {featured.data.subtitle && <p class="photo-feature__desc">{featured.data.subtitle}</p>}
                <div class="photo-feature__actions">
                  <a href={`/posts/${featured.slug}/`} class="photo-feature__link">进入作品</a>
                  {featured.data.gallery && featured.data.gallery.length > 1 && (
                    <span class="photo-feature__count">{featured.data.gallery.length} 张照片</span>
                  )}
                </div>
              </div>
            </article>
          );
        })()}

        <div class="photo-archive mt-16">
          <div class="photo-archive__head">
            <div>
              <p class="eyebrow">Archive</p>
              <p class="photo-archive__desc">按拍摄时间浏览全部作品。</p>
            </div>
            <a href="/tags/%E6%91%84%E5%BD%B1/" class="photo-archive__link">浏览摄影标签</a>
          </div>

          <nav class="photo-year-jump mt-6" aria-label="年份快速跳转">
            {groupedArchive.map((group) => (
              <a href={`#year-${group.year}`} class="photo-year-jump__link" data-year-link={String(group.year)}>{group.year}</a>
            ))}
          </nav>

          {groupedArchive.map((group) => (
            <section class="photo-year-group mt-10" id={`year-${group.year}`} data-year-group={String(group.year)}>
              <div class="photo-year-group__head">
                <h2 class="photo-year-group__title">{group.year}</h2>
                <p class="photo-year-group__count">{group.photos.length} 组作品</p>
              </div>

              <div class="photo-grid mt-6">
                {group.photos.map((photo, index) => {
                  const image = photo.data.gallery?.[0]?.src || getPreviewImage(photo);
                  if (!image) return null;
                  const tall = index % 5 === 0 || index % 5 === 3;
                  return (
                    <article class={`photo-card ${tall ? 'photo-card--tall' : 'photo-card--wide'}`}>
                      <a href={`/posts/${photo.slug}/`} class="photo-card__media">
                        <ProgressiveImage
                          src={image}
                          alt={photo.data.title || '摄影作品'}
                          class="photo-card__image"
                          loading="lazy"
                          decoding="async"
                        />
                      </a>
                      <div class="photo-card__body">
                        <p class="photo-card__meta">
                          {photo.data.date.toLocaleDateString('zh-CN')}
                          {photo.data.location ? ` · ${photo.data.location}` : ''}
                        </p>
                        <h2 class="photo-card__title"><a href={`/posts/${photo.slug}/`}>{photo.data.title || '未命名作品'}</a></h2>
                        <div class="photo-card__footer">
                          {photo.data.gallery && photo.data.gallery.length > 1 && <span>{photo.data.gallery.length} 张</span>}
                          {photo.data.camera?.model && <span>{photo.data.camera.model}</span>}
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          ))}
        </div>
      </div>
    </div>
  </section>
</SpotlightLayout>

<style>
  .photo-index-shell {
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 2rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.04), transparent 24%),
      linear-gradient(180deg, #070a10 0%, #0a0f16 100%);
    box-shadow: 0 28px 70px rgba(15, 23, 32, 0.12);
    color: rgba(238, 242, 247, 0.94);
  }

  .photo-index-shell :is(a, h1, h2, h3, strong) {
    color: rgba(248, 250, 252, 0.96);
  }

  .photo-index-shell .eyebrow {
    color: rgba(195, 203, 214, 0.64);
  }

  .photo-index-shell__title {
    color: rgba(248, 250, 252, 0.98);
  }

  .photo-index-hero {
    display: grid;
    gap: 2rem;
    align-items: end;
  }

  .photo-index-hero__lede {
    max-width: 34rem;
    color: rgba(195, 203, 214, 0.76);
    line-height: 1.9;
  }

  .photo-index-hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .photo-index-hero__stats div {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    padding: 0.9rem 1rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .photo-index-hero__stats span {
    display: block;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(195, 203, 214, 0.58);
  }

  .photo-index-hero__stats strong {
    display: block;
    margin-top: 0.4rem;
    font-size: clamp(1.1rem, 2.5vw, 1.65rem);
    font-weight: 600;
  }

  .photo-feature {
    display: grid;
    gap: 1.5rem;
    align-items: stretch;
  }

  .photo-feature__media {
    display: block;
    overflow: hidden;
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .photo-feature__image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .photo-feature__media:hover .photo-feature__image {
    transform: scale(1.02);
  }

  .photo-feature__content {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.4rem;
    padding: 1.35rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015));
  }

  .photo-feature__meta,
  .photo-card__meta {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: rgba(195, 203, 214, 0.62);
  }

  .photo-feature__title,
  .photo-card__title {
    margin: 0.55rem 0 0;
    font-size: clamp(1.4rem, 2.6vw, 2.4rem);
    line-height: 1.15;
  }

  .photo-feature__desc {
    max-width: 34rem;
    margin: 1rem 0 0;
    color: rgba(195, 203, 214, 0.74);
    line-height: 1.85;
  }

  .photo-feature__actions {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .photo-feature__link,
  .photo-archive__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    padding: 0.7rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.03);
    color: rgba(248, 250, 252, 0.92);
  }

  .photo-feature__count,
  .photo-card__footer span,
  .photo-archive__desc {
    font-size: 0.8rem;
    color: rgba(195, 203, 214, 0.68);
  }

  .photo-archive__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 1.25rem;
  }

  .photo-grid {
    display: grid;
    gap: 1.5rem;
  }

  .photo-year-jump {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    padding-bottom: 0.35rem;
    scrollbar-width: none;
  }

  .photo-year-jump::-webkit-scrollbar {
    display: none;
  }

  .photo-year-jump__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.3rem;
    padding: 0.55rem 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.02);
    color: rgba(195, 203, 214, 0.76);
    flex: 0 0 auto;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .photo-year-jump__link.is-active {
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.08);
    color: rgba(248, 250, 252, 0.96);
    transform: translateY(-1px);
  }

  .photo-year-group__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.25rem;
  }

  .photo-year-group__title {
    margin: 0;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: rgba(248, 250, 252, 0.96);
  }

  .photo-year-group__count {
    margin: 0;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(195, 203, 214, 0.58);
  }

  .photo-card {
    display: grid;
    gap: 0.9rem;
  }

  .photo-card__media {
    display: block;
    overflow: hidden;
    border-radius: 1.1rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .photo-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .photo-card__media:hover .photo-card__image {
    transform: scale(1.03);
  }

  .photo-card--tall .photo-card__media {
    aspect-ratio: 4 / 5;
  }

  .photo-card--wide .photo-card__media {
    aspect-ratio: 4 / 3;
  }

  .photo-card__body {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 0.85rem;
  }

  .photo-card__title {
    font-size: 1.1rem;
  }

  .photo-card__footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 0.7rem;
  }

  @media (min-width: 900px) {
    .photo-index-hero {
      grid-template-columns: minmax(0, 1.4fr) minmax(18rem, 0.9fr);
    }

    .photo-feature {
      grid-template-columns: minmax(0, 1.3fr) minmax(18rem, 0.75fr);
      gap: 2rem;
    }

    .photo-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: start;
    }

    .photo-card:nth-child(5n + 1),
    .photo-card:nth-child(5n + 4) {
      transform: translateY(1.25rem);
    }
  }

  @media (max-width: 640px) {
    .photo-index-shell {
      border-radius: 1.4rem;
      padding: 1rem;
    }

    .photo-index-hero__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .photo-archive__head {
      align-items: flex-start;
      flex-direction: column;
    }

    .photo-year-group__head {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

<script>
  const yearLinks = Array.from(document.querySelectorAll('[data-year-link]'));
  const yearGroups = Array.from(document.querySelectorAll('[data-year-group]'));

  if (yearLinks.length && yearGroups.length) {
    const syncYearState = (year) => {
      yearLinks.forEach((link) => {
        link.classList.toggle('is-active', link.getAttribute('data-year-link') === String(year));
      });
    };

    const observer = new IntersectionObserver((entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

      if (!visible) return;
      const year = visible.target.getAttribute('data-year-group');
      if (year) syncYearState(year);
    }, { threshold: [0.2, 0.45], rootMargin: '-18% 0px -55% 0px' });

    yearGroups.forEach((group) => observer.observe(group));
    syncYearState(yearGroups[0].getAttribute('data-year-group'));
  }
</script>
