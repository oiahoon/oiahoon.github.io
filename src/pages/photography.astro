---
import { getCollection } from 'astro:content';
import SpotlightLayout from '../layouts/SpotlightLayout.astro';
import ProgressiveImage from '../components/ProgressiveImage.astro';

const photos = await getCollection('posts', ({ data }) => !data.draft && data.type === 'photography');
const sorted = photos.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const selected = sorted.slice(0, 6);
const archive = sorted.slice(0);
const filters = [
  { label: 'All', value: 'all' },
  { label: 'Cafe', value: 'cafe' },
  { label: 'Street', value: 'street' },
  { label: 'Transit', value: 'transit' },
  { label: 'Harbour', value: 'harbour' },
  { label: 'Trees', value: 'trees' },
  { label: 'Film', value: 'film' },
] as const;
const years = [...new Set(sorted.map((photo) => photo.data.date.getFullYear()))].sort((a, b) => b - a);

function firstImage(photo: typeof sorted[number]) {
  return photo.data.gallery?.[0];
}

function cardMeta(photo: typeof sorted[number], includeCamera = false) {
  const values = [photo.data.location, String(photo.data.date.getFullYear())];
  if (includeCamera && photo.data.camera?.model) {
    values.push(photo.data.camera.model.replace('Leica Camera AG, ', '').replace('Hasselblad, ', ''));
  }
  return values.filter(Boolean).join(' · ');
}

function filterGroups(photo: typeof sorted[number]) {
  const haystack = [
    photo.data.title,
    photo.data.description,
    photo.data.location,
    photo.data.camera?.model,
    photo.data.camera?.lens,
    ...(photo.data.tags ?? []),
    ...(photo.data.gallery ?? []).flatMap((image) => [image.alt, image.caption]),
  ].filter(Boolean).join(' ').toLowerCase();

  const groups = new Set<string>(['all']);
  if (haystack.includes('cafe') || haystack.includes('coffee') || haystack.includes('bakery') || haystack.includes('咖啡')) groups.add('cafe');
  if (haystack.includes('street') || haystack.includes('road') || haystack.includes('taxi') || haystack.includes('motorcycle') || haystack.includes('cyclist') || haystack.includes('街')) groups.add('street');
  if (haystack.includes('train') || haystack.includes('taxi') || haystack.includes('road') || haystack.includes('车厢') || haystack.includes('出租车')) groups.add('transit');
  if (haystack.includes('harbour') || haystack.includes('skyline') || haystack.includes('boat') || haystack.includes('海') || haystack.includes('港')) groups.add('harbour');
  if (haystack.includes('tree') || haystack.includes('canopy') || haystack.includes('flowers') || haystack.includes('树') || haystack.includes('花')) groups.add('trees');
  if (haystack.includes('noritsu') || haystack.includes('film') || haystack.includes('胶片')) groups.add('film');

  return [...groups].join(' ');
}
---

<SpotlightLayout title="Photographs | Joey's Notes" description="Personal photographs from cafes, streets, transit windows, trees, and quiet daily light." lang="zh">
  <section class="photo-index-page">
    <div class="photo-shell shell">
      <header class="photo-intro">
        <p class="eyebrow">Photography</p>
        <div class="photo-intro__grid">
          <div>
            <h1>Personal photographs from streets, cafes, and elsewhere.</h1>
            <p>街头、车窗、咖啡馆、树影与水面里的安静片段。使用 Leica、Hasselblad、胶片与数码记录。</p>
          </div>
          <dl class="photo-index-stats" aria-label="摄影归档概览">
            <div>
              <dt>Photographs</dt>
              <dd>{sorted.length}</dd>
            </div>
            <div>
              <dt>Latest year</dt>
              <dd>{years[0]}</dd>
            </div>
            <div>
              <dt>Archive</dt>
              <dd>{years.length}</dd>
            </div>
          </dl>
        </div>
      </header>

      <section class="photo-section" aria-labelledby="selected-title">
        <div class="photo-section__head">
          <div>
            <h2 id="selected-title">Selected photographs</h2>
            <nav class="filter-index" aria-label="摄影筛选索引">
              {filters.map((filter, index) => (
                <a
                  href={index === 0 ? '/photography/' : `/photography/?tag=${filter.value}`}
                  aria-current={index === 0 ? 'page' : undefined}
                  data-photo-filter={filter.value}
                >
                  {filter.label}
                </a>
              ))}
            </nav>
          </div>
          <p>不是“最新作品”，而是我作为作者最愿意让读者先看的图。</p>
        </div>

        <div class="selected-photo-grid">
          {selected.map((photo, index) => {
            const image = firstImage(photo);
            if (!image) return null;
            const size = index === 0 ? 'is-lead' : index === 1 || index === 3 ? 'is-medium' : 'is-small';
            return (
              <article class={`photo-tile ${size}`} data-photo-filter-groups={filterGroups(photo)}>
                <a href={`/posts/${photo.slug}/`} class="photo-tile__media" data-astro-prefetch>
                  <ProgressiveImage
                    src={image.src}
                    alt={image.alt || photo.data.title || 'Photograph'}
                    class="photo-tile__image"
                    loading={index < 2 ? 'eager' : 'lazy'}
                    decoding="async"
                    width={image.width}
                    height={image.height}
                    sizes={index === 0 ? '(min-width: 960px) 54vw, 100vw' : '(min-width: 960px) 30vw, 50vw'}
                    style={`view-transition-name: photo-cover-${photo.slug};`}
                  />
                </a>
                <h3><a href={`/posts/${photo.slug}/`} data-astro-prefetch style={`view-transition-name: photo-title-${photo.slug};`}>{photo.data.title}</a></h3>
                <p>{cardMeta(photo, index > 0)}</p>
              </article>
            );
          })}
        </div>
      </section>

      <section class="photo-section" aria-labelledby="archive-title">
        <div class="photo-section__head">
          <div>
            <p class="eyebrow">Archive</p>
            <h2 id="archive-title">Archive · {years[0]}</h2>
          </div>
          <p>归档区保持高效率浏览，但标题和地点仍然存在。</p>
        </div>

        <div class="archive-grid">
          {archive.map((photo) => {
            const image = firstImage(photo);
            if (!image) return null;
            return (
              <article class="archive-card" data-photo-filter-groups={filterGroups(photo)}>
                <a href={`/posts/${photo.slug}/`} data-astro-prefetch>
                  <ProgressiveImage
                    src={image.src}
                    alt={image.alt || photo.data.title || 'Photograph'}
                    class="archive-card__image"
                    loading="lazy"
                    decoding="async"
                    width={image.width}
                    height={image.height}
                    sizes="(min-width: 960px) 18vw, 45vw"
                  />
                </a>
                <h3><a href={`/posts/${photo.slug}/`} data-astro-prefetch>{photo.data.title}</a></h3>
                <p>{photo.data.location} · {photo.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</p>
              </article>
            );
          })}
        </div>
      </section>
    </div>
  </section>
</SpotlightLayout>

<style>
  .photo-index-page {
    margin-top: 0;
    padding-block: clamp(2.8rem, 6vw, 5rem) clamp(4rem, 8vw, 7rem);
    background:
      radial-gradient(circle at top, rgba(208, 138, 114, 0.08), transparent 24%),
      linear-gradient(180deg, #11100e 0%, #141210 54%, #11100e 100%);
    color: #eee7dc;
  }

  .photo-shell {
    width: min(100%, 92rem);
  }

  .photo-shell :is(h1, h2, h3, a, dd) {
    color: #eee7dc;
  }

  .photo-shell .eyebrow,
  .photo-shell p,
  .photo-shell dt {
    color: #aaa197;
  }

  .photo-intro {
    padding-top: clamp(1rem, 2vw, 2rem);
  }

  .photo-intro__grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: end;
    margin-top: 1.2rem;
  }

  .photo-intro h1 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(3.2rem, 8vw, 6.4rem);
    line-height: 0.98;
    font-weight: 600;
  }

  .photo-intro p {
    max-width: 39rem;
    margin: 1.35rem 0 0;
    font-size: clamp(1rem, 2vw, 1.18rem);
    line-height: 1.85;
  }

  .photo-index-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.4rem;
    border-top: 1px solid #34302b;
    padding-top: 1.5rem;
  }

  .photo-index-stats div,
  .photo-index-stats dd,
  .photo-index-stats dt {
    margin: 0;
  }

  .photo-index-stats dt {
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .photo-index-stats dd {
    margin-top: 0.45rem;
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.7rem);
    line-height: 1;
  }

  .photo-section {
    margin-top: clamp(4rem, 8vw, 7rem);
    border-top: 1px solid #34302b;
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .photo-section__head {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .photo-section h2 {
    margin: 0;
    font-size: clamp(2.1rem, 5vw, 3.5rem);
    line-height: 1.05;
    font-weight: 600;
  }

  .photo-section__head > p {
    max-width: 25rem;
    margin: 0;
    line-height: 1.8;
  }

  .filter-index {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 1rem;
    margin-top: 1.4rem;
  }

  .filter-index a {
    color: #aaa197;
    font-size: 0.95rem;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .filter-index a:hover,
  .filter-index a[aria-current='page'] {
    color: #eee7dc;
    text-decoration: underline;
    text-underline-offset: 0.35em;
  }

  .selected-photo-grid,
  .archive-grid {
    display: grid;
    gap: clamp(1rem, 2vw, 1.65rem);
    margin-top: 2rem;
  }

  .photo-tile[hidden],
  .archive-card[hidden] {
    display: none;
  }

  .selected-photo-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .photo-tile.is-lead {
    grid-column: 1 / -1;
  }

  .photo-tile__media,
  .archive-card a:first-child {
    display: block;
    overflow: hidden;
    background: #191816;
  }

  .photo-tile__image,
  .archive-card__image {
    width: 100%;
    transition:
      transform var(--duration-slow) var(--ease-standard),
      opacity var(--duration-base) var(--ease-standard);
  }

  .photo-tile__image {
    aspect-ratio: 4 / 3;
  }

  .archive-card__image {
    aspect-ratio: 1 / 1;
  }

  .photo-tile:hover .photo-tile__image,
  .archive-card:hover .archive-card__image {
    transform: scale(1.018);
  }

  .photo-tile h3,
  .archive-card h3 {
    margin: 0.85rem 0 0;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.8vw, 1.18rem);
    line-height: 1.35;
  }

  .photo-tile p,
  .archive-card p {
    margin: 0.22rem 0 0;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .archive-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (min-width: 760px) {
    .photo-intro__grid,
    .photo-section__head {
      grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
    }

    .archive-grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }

  @media (min-width: 960px) {
    .selected-photo-grid {
      grid-template-columns: repeat(12, minmax(0, 1fr));
    }

    .photo-tile.is-lead {
      grid-column: span 7;
      grid-row: span 2;
    }

    .photo-tile.is-medium {
      grid-column: span 5;
    }

    .photo-tile.is-small {
      grid-column: span 4;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-tile__image,
    .archive-card__image {
      transition: none;
    }
  }
</style>

<script>
  (() => {
    const root = document.querySelector('.photo-index-page');
    if (!root || root.dataset.photoFiltersBound === 'true') return;

    const links = Array.from(root.querySelectorAll('[data-photo-filter]'));
    const items = Array.from(root.querySelectorAll('[data-photo-filter-groups]'));
    if (!links.length || !items.length) return;

    root.dataset.photoFiltersBound = 'true';
    const controller = new AbortController();
    const filters = new Set(links.map((link) => link.getAttribute('data-photo-filter')).filter(Boolean));

    function getFilterFromUrl() {
      const tag = new URL(window.location.href).searchParams.get('tag') || 'all';
      return filters.has(tag) ? tag : 'all';
    }

    function updateUrl(filter) {
      const url = new URL(window.location.href);
      if (filter === 'all') {
        url.searchParams.delete('tag');
      } else {
        url.searchParams.set('tag', filter);
      }
      url.hash = '';
      history.pushState({ photoFilter: filter }, '', url);
    }

    function applyFilter(filter) {
      items.forEach((item) => {
        const groups = (item.getAttribute('data-photo-filter-groups') || '').split(/\s+/);
        item.hidden = filter !== 'all' && !groups.includes(filter);
      });

      links.forEach((link) => {
        const active = link.getAttribute('data-photo-filter') === filter;
        if (active) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    }

    links.forEach((link) => {
      link.addEventListener('click', (event) => {
        const filter = link.getAttribute('data-photo-filter') || 'all';
        event.preventDefault();
        applyFilter(filter);
        updateUrl(filter);
      }, { signal: controller.signal });
    });

    window.addEventListener('popstate', () => applyFilter(getFilterFromUrl()), { signal: controller.signal });
    document.addEventListener('astro:before-swap', () => controller.abort(), { once: true, signal: controller.signal });
    applyFilter(getFilterFromUrl());
  })();
</script>
