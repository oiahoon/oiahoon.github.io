---
import { getCollection } from 'astro:content';
import SpotlightLayout from '../layouts/SpotlightLayout.astro';
import { getPreviewImage } from '../utils/extractFirstImage';
import ProgressiveImage from '../components/ProgressiveImage.astro';
import UiIcon from '../components/UiIcon.astro';

const photos = await getCollection('posts', ({ data }) => !data.draft && data.type === 'photography');
const sorted = photos.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const featured = sorted[0];
const remaining = sorted.slice(1);
const years = [...new Set(sorted.map((photo) => photo.data.date.getFullYear()))].sort((a, b) => b - a);
const latestYear = years[0];
const earliestYear = years[years.length - 1];
const totalImages = sorted.reduce((sum, photo) => sum + (photo.data.gallery?.length || 1), 0);
const groupedArchive = years.map((year) => ({
  year,
  photos: remaining.filter((photo) => photo.data.date.getFullYear() === year),
})).filter((group) => group.photos.length > 0);
---

<SpotlightLayout title="摄影作品 | Joey's Notes" description="摄影归档" lang="zh">
  <section class="section-gap photo-index-page">
    <div class="photo-index-shell shell">
        <div class="photo-index-hero">
          <div>
            <p class="eyebrow section-kicker photo-kicker"><UiIcon name="camera" size={14} /> <span>Photography</span></p>
            <h1 class="mt-4 text-4xl font-semibold photo-index-shell__title">摄影作品</h1>
          </div>

          <div class="photo-index-hero__stats">
            <div>
              <span><UiIcon name="archive" size={13} />作品</span>
              <strong>{sorted.length}</strong>
            </div>
            <div>
              <span><UiIcon name="image" size={13} />照片</span>
              <strong>{totalImages}</strong>
            </div>
            <div>
              <span><UiIcon name="calendar" size={13} />时间</span>
              <strong>{latestYear === earliestYear ? latestYear : `${earliestYear} - ${latestYear}`}</strong>
            </div>
          </div>
        </div>

        {featured && (() => {
          const image = featured.data.gallery?.[0]?.src || getPreviewImage(featured);
          if (!image) return null;
          return (
            <article class="photo-feature mt-12">
              <a href={`/posts/${featured.slug}/`} class="photo-feature__media" data-astro-prefetch>
                <ProgressiveImage
                  src={image}
                  alt={featured.data.title || '摄影作品'}
                  class="photo-feature__image"
                  loading="eager"
                  decoding="async"
                  style={`view-transition-name: photo-cover-${featured.slug};`}
                />
              </a>
              <div class="photo-feature__content">
                <div class="photo-feature__lead">
                  <p class="photo-feature__eyebrow"><UiIcon name="image" size={13} /> <span>最新作品</span></p>
                  <p class="photo-feature__meta">
                    {featured.data.date.toLocaleDateString('zh-CN')}
                    {featured.data.location ? ` · ${featured.data.location}` : ''}
                  </p>
                </div>
                {featured.data.title && (
                  <h2 class="photo-feature__title">
                    <a href={`/posts/${featured.slug}/`}>{featured.data.title}</a>
                  </h2>
                )}
                {featured.data.subtitle && <p class="photo-feature__desc">{featured.data.subtitle}</p>}
                {(featured.data.camera?.model || (featured.data.gallery && featured.data.gallery.length > 1)) && (
                  <p class="photo-feature__specs">
                    {featured.data.camera?.model}
                    {featured.data.camera?.model && featured.data.gallery && featured.data.gallery.length > 1 ? ' · ' : ''}
                    {featured.data.gallery && featured.data.gallery.length > 1 ? `${featured.data.gallery.length} 张照片` : ''}
                  </p>
                )}
                <div class="photo-feature__actions">
                  <a href={`/posts/${featured.slug}/`} class="photo-feature__link" data-astro-prefetch><span>进入作品</span><UiIcon name="arrowRight" size={14} /></a>
                </div>
              </div>
            </article>
          );
        })()}

        <div class="photo-archive mt-16">
          <div class="photo-archive__head">
            <div>
              <p class="eyebrow section-kicker photo-kicker"><UiIcon name="archive" size={14} /> <span>Archive</span></p>
              <p class="photo-archive__desc">按拍摄时间浏览全部作品。</p>
            </div>
            <a href="/tags/%E6%91%84%E5%BD%B1/" class="photo-archive__link"><span>浏览摄影标签</span><UiIcon name="tag" size={14} /></a>
          </div>

          <nav class="photo-year-jump mt-6" aria-label="年份快速跳转">
            {groupedArchive.map((group) => (
              <a href={`#year-${group.year}`} class="photo-year-jump__link" data-year-link={String(group.year)}>{group.year}</a>
            ))}
          </nav>

          {groupedArchive.map((group) => (
            <section class="photo-year-group mt-10" id={`year-${group.year}`} data-year-group={String(group.year)}>
              <div class="photo-year-group__head">
                <h2 class="photo-year-group__title">{group.year}</h2>
                <p class="photo-year-group__count">{group.photos.length} 组作品</p>
              </div>

              <div class="photo-grid mt-6">
                {group.photos.map((photo) => {
                  const image = photo.data.gallery?.[0]?.src || getPreviewImage(photo);
                  if (!image) return null;
                  return (
                    <article class="photo-card">
                      <a href={`/posts/${photo.slug}/`} class="photo-card__media" data-astro-prefetch>
                        <ProgressiveImage
                          src={image}
                          alt={photo.data.title || '摄影作品'}
                          class="photo-card__image"
                          loading="lazy"
                          decoding="async"
                          style={`view-transition-name: photo-cover-${photo.slug};`}
                        />
                      </a>
                      <div class="photo-card__body">
                        {photo.data.title && (
                          <h2 class="photo-card__title"><a href={`/posts/${photo.slug}/`} data-astro-prefetch>{photo.data.title}</a></h2>
                        )}
                        <div class="photo-card__footer">
                          <span><UiIcon name="calendar" size={12} />{photo.data.date.toLocaleDateString('zh-CN')}</span>
                          {photo.data.location && <span>{photo.data.location}</span>}
                          {photo.data.gallery && photo.data.gallery.length > 1 && <span>{photo.data.gallery.length} 张</span>}
                          {photo.data.camera?.model && <span>{photo.data.camera.model}</span>}
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          ))}
        </div>
    </div>
  </section>
</SpotlightLayout>

<style>
  .photo-index-page {
    margin-top: 0;
    padding-block: clamp(2.5rem, 5vw, 4rem);
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.05), transparent 20%),
      linear-gradient(180deg, #05070b 0%, #070a10 58%, #080c12 100%);
  }

  .photo-index-shell {
    width: min(100%, 96rem);
    padding-inline: clamp(1.1rem, 3vw, 2.2rem);
    color: rgba(238, 242, 247, 0.94);
  }

  .photo-index-shell :is(a, h1, h2, h3, strong) {
    color: rgba(248, 250, 252, 0.96);
  }

  .photo-index-shell .eyebrow {
    color: rgba(195, 203, 214, 0.64);
  }

  .photo-index-shell__title {
    color: rgba(248, 250, 252, 0.98);
  }

  .photo-index-hero {
    display: grid;
    gap: 2rem;
    align-items: end;
  }

  .photo-index-hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .photo-index-hero__stats div {
    padding-top: 0.15rem;
  }

  .photo-index-hero__stats span {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(195, 203, 214, 0.5);
  }

  .photo-index-hero__stats strong {
    display: block;
    margin-top: 0.55rem;
    font-size: clamp(1.2rem, 2.8vw, 1.8rem);
    font-weight: 600;
  }

  .photo-feature {
    position: relative;
    overflow: hidden;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .photo-feature__media {
    display: block;
  }

  .photo-feature__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .photo-feature__media:hover .photo-feature__image {
    transform: scale(1.02);
  }

  .photo-feature__content {
    position: absolute;
    left: 0;
    right: auto;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.55rem;
    width: min(32rem, 78%);
    min-height: 36%;
    padding: clamp(1rem, 2.2vw, 1.5rem);
    background:
      linear-gradient(180deg, rgba(5, 7, 11, 0) 0%, rgba(5, 7, 11, 0.18) 34%, rgba(5, 7, 11, 0.72) 100%);
  }

  .photo-feature__lead {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .photo-feature__eyebrow {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.56);
  }

  .photo-feature__meta {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: rgba(195, 203, 214, 0.62);
  }

  .photo-feature__title,
  .photo-card__title {
    margin: 0;
    font-size: clamp(1.4rem, 2.6vw, 2.4rem);
    line-height: 1.15;
  }

  .photo-feature__desc {
    max-width: 32rem;
    margin: 0.1rem 0 0;
    color: rgba(226, 232, 240, 0.72);
    line-height: 1.68;
  }

  .photo-feature__specs {
    margin: 0.1rem 0 0;
    font-size: 0.76rem;
    color: rgba(226, 232, 240, 0.56);
  }

  .photo-feature__actions {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 0.4rem;
  }

  .photo-feature__link,
  .photo-archive__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.4rem;
    padding: 0.62rem 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.03);
    color: rgba(248, 250, 252, 0.88);
    font-size: 0.84rem;
  }

  .photo-feature__link,
  .photo-archive__link {
    gap: 0.42rem;
  }

  .photo-card__footer span,
  .photo-archive__desc {
    font-size: 0.8rem;
    color: rgba(195, 203, 214, 0.58);
  }

  .photo-card__footer span {
    display: inline-flex;
    align-items: center;
    gap: 0.26rem;
  }

  .photo-archive__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 1.25rem;
  }

  .photo-grid {
    display: grid;
    gap: 1.5rem;
  }

  .photo-year-jump {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    padding-bottom: 0.35rem;
    scrollbar-width: none;
  }

  .photo-year-jump::-webkit-scrollbar {
    display: none;
  }

  .photo-year-jump__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.15rem;
    padding: 0.48rem 0.82rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.015);
    color: rgba(195, 203, 214, 0.68);
    flex: 0 0 auto;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .photo-year-jump__link.is-active {
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.05);
    color: rgba(248, 250, 252, 0.96);
    transform: translateY(-1px);
  }

  .photo-year-group__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.25rem;
  }

  .photo-year-group__title {
    margin: 0;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: rgba(248, 250, 252, 0.96);
  }

  .photo-year-group__count {
    margin: 0;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(195, 203, 214, 0.58);
  }

  .photo-card {
    display: grid;
    gap: 0.7rem;
  }

  .photo-card__media {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 1.1rem;
    background: rgba(255, 255, 255, 0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .photo-card__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5, 7, 11, 0) 38%, rgba(5, 7, 11, 0.18) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .photo-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease, filter 0.45s ease;
  }

  .photo-card__media:hover .photo-card__image {
    transform: scale(1.035);
    filter: saturate(1.04);
  }

  .photo-card__media:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 38px rgba(0, 0, 0, 0.22);
  }

  .photo-card__media:hover::after {
    opacity: 1;
  }

  .photo-card__media {
    aspect-ratio: 4 / 3;
  }

  .photo-card__body {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 0.58rem;
    transition: transform 0.25s ease;
  }

  .photo-card:hover .photo-card__body {
    transform: translateY(-1px);
  }

  .photo-card__title {
    font-size: 1rem;
  }

  .photo-card__footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.15rem;
    font-size: 0.72rem;
    color: rgba(195, 203, 214, 0.5);
    line-height: 1.45;
  }

  .photo-card__footer span + span::before {
    content: '·';
    margin-right: 0.45rem;
    color: rgba(195, 203, 214, 0.28);
  }

  @media (min-width: 900px) {
    .photo-index-hero {
      grid-template-columns: minmax(0, 1.4fr) minmax(18rem, 0.9fr);
    }

    .photo-feature {
      min-height: clamp(24rem, 44vw, 38rem);
    }

    .photo-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: start;
    }
  }

  @media (max-width: 640px) {
    .photo-index-shell {
      padding-inline: 1rem;
    }

    .photo-index-hero__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .photo-archive__head {
      align-items: flex-start;
      flex-direction: column;
    }

    .photo-feature__content {
      width: 100%;
      min-height: 44%;
      right: 0;
    }

    .photo-year-group__head {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

<script>
  const yearLinks = Array.from(document.querySelectorAll('[data-year-link]'));
  const yearGroups = Array.from(document.querySelectorAll('[data-year-group]'));

  if (yearLinks.length && yearGroups.length) {
    const syncYearState = (year) => {
      yearLinks.forEach((link) => {
        link.classList.toggle('is-active', link.getAttribute('data-year-link') === String(year));
      });
      const activeLink = yearLinks.find((link) => link.getAttribute('data-year-link') === String(year));
      activeLink?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    };

    const observer = new IntersectionObserver((entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

      if (!visible) return;
      const year = visible.target.getAttribute('data-year-group');
      if (year) syncYearState(year);
    }, { threshold: [0.2, 0.45], rootMargin: '-18% 0px -55% 0px' });

    yearGroups.forEach((group) => observer.observe(group));
    syncYearState(yearGroups[0].getAttribute('data-year-group'));
  }
</script>
