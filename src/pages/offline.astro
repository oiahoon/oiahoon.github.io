---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout 
  title="离线模式 | Joey's Notes"
  description="您当前处于离线状态"
>
  <section class="section-gap offline-page">
    <div class="shell">
      <div class="content-narrow offline-state">
        <p class="eyebrow">Offline</p>
        <h1>您当前处于离线状态</h1>
        <p class="muted">
          网络恢复后可以继续访问；此前缓存过的页面仍可能打开。
        </p>

        <div class="offline-actions">
          <button
            onclick="window.location.reload()"
          >
            重新连接
          </button>
          <a href="/">返回首页</a>
        </div>
      </div>
    </div>
  </section>
</BlogLayout>

<script>
  function updateOnlineStatus() {
    if (navigator.onLine) {
      window.location.reload();
    }
  }

  window.addEventListener('online', updateOnlineStatus);
</script>

<style>
  .offline-page {
    min-height: clamp(28rem, 58vh, 42rem);
    display: flex;
    align-items: center;
  }

  .offline-state {
    text-align: center;
  }

  .offline-state h1 {
    margin-top: 1rem;
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    line-height: 1.05;
    font-weight: 650;
    letter-spacing: 0;
  }

  .offline-state p {
    max-width: 32rem;
    margin: 1.3rem auto 0;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .offline-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2.3rem;
  }

  .offline-actions button,
  .offline-actions a {
    min-height: 2.75rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    padding: 0.68rem 1.15rem;
    font-size: 0.92rem;
    font-weight: 560;
    transition:
      color 160ms ease,
      background 160ms ease,
      border-color 160ms ease;
  }

  .offline-actions button {
    border-color: var(--accent);
    background: var(--accent);
    color: white;
  }

  .offline-actions a {
    color: var(--muted);
  }

  .offline-actions button:hover,
  .offline-actions a:hover {
    border-color: var(--text);
    color: var(--text);
  }

  .offline-actions button:hover {
    background: transparent;
  }
</style>
