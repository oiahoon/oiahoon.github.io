---
const year = new Date().getFullYear();
const isPhotoArchive = Astro.url.pathname === '/photography/';
---

<footer class={`mt-24 pb-12 ${isPhotoArchive ? 'spotlight-footer--inverse' : ''}`}>
  <div class="shell">
    <div class="border-t pt-8" style="border-color: var(--line);">
      <div class="grid gap-8 text-sm md:grid-cols-3">
        <section aria-labelledby="footer-about-title">
          <h2 id="footer-about-title" class="font-sans text-base font-semibold">Joey's Notes</h2>
          <p class="mt-3 max-w-xs muted">Photographs, field notes, and a legacy archive of engineering notes.</p>
        </section>

        <nav aria-labelledby="footer-navigation-title">
          <h2 id="footer-navigation-title" class="font-sans font-semibold">导航</h2>
          <div class="mt-3 flex flex-col gap-2 muted">
            <a href="/photography/" class="footer-link hover:text-[var(--text)]" data-astro-prefetch>Photographs</a>
            <a href="/articles/" class="footer-link hover:text-[var(--text)]" data-astro-prefetch>Notes</a>
            <a href="/about/" class="footer-link hover:text-[var(--text)]" data-astro-prefetch>About</a>
            <a href="/tags/" class="footer-link hover:text-[var(--text)]" data-astro-prefetch>Tags</a>
          </div>
        </nav>

        <section aria-labelledby="footer-links-title">
          <h2 id="footer-links-title" class="font-sans font-semibold">订阅与链接</h2>
          <div class="mt-3 flex flex-col gap-2 muted">
            <a href="/rss.xml" class="footer-link hover:text-[var(--text)]">RSS 订阅</a>
            <a href="https://github.com/oiahoon" target="_blank" rel="noopener noreferrer" class="footer-link hover:text-[var(--text)]">GitHub</a>
            <a href="https://weibo.com/desiver" target="_blank" rel="noopener noreferrer" class="footer-link hover:text-[var(--text)]">微博</a>
            <a href="mailto:4296411@qq.com" class="footer-link hover:text-[var(--text)]">Email</a>
          </div>
        </section>
      </div>

      <div class="mt-8 border-t pt-4 text-xs muted" style="border-color: var(--line);">
        <p>© {year} Joey's Notes</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    display: inline-flex;
    min-height: 2rem;
    align-items: center;
    text-decoration: none;
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.28em;
  }

  .footer-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 55%, transparent);
    outline-offset: 3px;
  }

  .spotlight-footer--inverse {
    margin-top: 0;
    background: #080c12;
    color: rgba(238, 242, 247, 0.92);
  }

  .spotlight-footer--inverse p:first-child,
  .spotlight-footer--inverse .font-semibold,
  .spotlight-footer--inverse .text-base {
    color: rgba(248, 250, 252, 0.96);
  }

  .spotlight-footer--inverse .muted,
  .spotlight-footer--inverse a {
    color: rgba(195, 203, 214, 0.74);
  }

  .spotlight-footer--inverse a:hover {
    color: rgba(248, 250, 252, 0.96);
  }
</style>
