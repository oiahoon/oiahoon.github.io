---
const year = new Date().getFullYear();
const isPhotoArchive = Astro.url.pathname === '/photography/';
---

<footer class={`mt-24 pb-12 ${isPhotoArchive ? 'spotlight-footer--inverse' : ''}`}>
  <div class="shell">
    <div class="border-t pt-8" style="border-color: var(--line);">
      <div class="grid gap-8 text-sm md:grid-cols-3">
        <section>
          <p class="text-base font-semibold">Joey's Notes</p>
          <p class="mt-3 max-w-xs muted">Photographs, field notes, and a legacy archive of engineering notes.</p>
        </section>

        <section>
          <p class="font-semibold">导航</p>
          <div class="mt-3 flex flex-col gap-2 muted">
            <a href="/photography/" class="hover:text-[var(--text)]" data-astro-prefetch>Photographs</a>
            <a href="/articles/" class="hover:text-[var(--text)]" data-astro-prefetch>Notes</a>
            <a href="/about/" class="hover:text-[var(--text)]" data-astro-prefetch>About</a>
            <a href="/tags/" class="hover:text-[var(--text)]" data-astro-prefetch>Tags</a>
          </div>
        </section>

        <section>
          <p class="font-semibold">订阅与链接</p>
          <div class="mt-3 flex flex-col gap-2 muted">
            <a href="/rss.xml" class="hover:text-[var(--text)]">RSS 订阅</a>
            <a href="https://github.com/oiahoon" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text)]">GitHub</a>
            <a href="https://weibo.com/desiver" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text)]">微博</a>
            <a href="mailto:4296411@qq.com" class="hover:text-[var(--text)]">Email</a>
          </div>
        </section>
      </div>

      <div class="mt-8 border-t pt-4 text-xs muted" style="border-color: var(--line);">
        <p>© {year} Joey's Notes</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .spotlight-footer--inverse {
    margin-top: 0;
    background: #080c12;
    color: rgba(238, 242, 247, 0.92);
  }

  .spotlight-footer--inverse p:first-child,
  .spotlight-footer--inverse .font-semibold,
  .spotlight-footer--inverse .text-base {
    color: rgba(248, 250, 252, 0.96);
  }

  .spotlight-footer--inverse .muted,
  .spotlight-footer--inverse a {
    color: rgba(195, 203, 214, 0.74);
  }

  .spotlight-footer--inverse a:hover {
    color: rgba(248, 250, 252, 0.96);
  }
</style>
