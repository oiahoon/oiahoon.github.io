---
import UiIcon from './UiIcon.astro';

export interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;
const currentPath = Astro.url.pathname;
const isPhotoArchive = currentPath === '/photography/';
const themeLabel = lang === 'zh' ? '深色' : 'Dark';
const themeAriaLabel = lang === 'zh' ? '切换到深色主题' : 'Switch to dark theme';
const navigationLabel = lang === 'zh' ? '导航' : 'Navigation';

const navigation = [
  { name: 'Photographs', href: '/photography/', icon: 'camera' },
  { name: 'Notes', href: '/articles/', icon: 'article' },
  { name: 'About', href: '/about/', icon: 'about' },
] as const;
---

<header class={`pt-8 sm:pt-10 ${isPhotoArchive ? 'spotlight-header--inverse' : ''}`}>
  <div class="shell">
    <div class="flex items-center justify-between gap-4 border-b pb-5 spotlight-header__bar" style="border-color: var(--line);">
      <a href="/" class="spotlight-header__brand text-lg font-semibold tracking-tight text-[var(--text)]" data-astro-prefetch style="view-transition-name: site-brand;">
        <UiIcon name="notebook" size={17} class="spotlight-header__brand-icon" />
        <span>Joey's Notes</span>
      </a>

      <nav class="hidden items-center gap-6 text-sm md:flex">
        {navigation.map((item) => {
          const active = currentPath === item.href;
          return (
            <a href={item.href} class={`relative transition spotlight-header__link ${active ? 'font-semibold text-[var(--text)]' : 'muted hover:text-[var(--text)]'}`} aria-current={active ? 'page' : undefined} data-astro-prefetch>
              <UiIcon name={item.icon} size={13} class="spotlight-header__nav-icon" />
              <span>{item.name}</span>
              {active && <span class="absolute -bottom-1 left-0 right-0 h-px bg-[var(--accent)]" />}
            </a>
          );
        })}
      </nav>

      <div class="flex items-center gap-2">
        {!isPhotoArchive && (
          <button
            type="button"
            data-theme-toggle
            class="spotlight-header__button spotlight-header__theme-toggle rounded-full border px-3 py-1.5 text-xs font-medium transition hover:bg-black/5 dark:hover:bg-white/10"
            style="border-color: var(--line); color: var(--text);"
            aria-label={themeAriaLabel}
            aria-pressed="false"
          >
            <UiIcon name="moon" size={14} class="spotlight-header__theme-icon spotlight-header__theme-icon--dark" />
            <UiIcon name="sun" size={14} class="spotlight-header__theme-icon spotlight-header__theme-icon--light" />
            <span data-theme-toggle-label>{themeLabel}</span>
          </button>
        )}

        <details class="spotlight-header__menu-shell relative md:hidden">
          <summary class="spotlight-header__button spotlight-header__menu-toggle cursor-pointer list-none rounded-full border px-3 py-1.5 text-xs font-medium" style="border-color: var(--line); color: var(--text);" aria-label={navigationLabel}>
            <UiIcon name="menu" size={16} />
          </summary>
          <nav class="spotlight-header__menu absolute right-5 mt-2 min-w-40 rounded-xl border bg-[var(--surface)] p-2 text-sm shadow-sm" style="border-color: var(--line);" aria-label={navigationLabel}>
            {navigation.map((item) => (
              <a href={item.href} class="spotlight-header__menu-link muted flex items-center gap-2 rounded-lg px-3 py-2 hover:bg-black/5 hover:text-[var(--text)] dark:hover:bg-white/5" aria-current={currentPath === item.href ? 'page' : undefined} data-astro-prefetch>
                <UiIcon name={item.icon} size={14} />
                <span>{item.name}</span>
              </a>
            ))}
          </nav>
        </details>
      </div>
    </div>
  </div>
</header>

<style>
  .spotlight-header--inverse {
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.04), transparent 22%),
      linear-gradient(180deg, #05070b 0%, #070a10 100%);
  }

  .spotlight-header__brand,
  .spotlight-header__link,
  .spotlight-header__theme-toggle {
    display: inline-flex;
    align-items: center;
  }

  .spotlight-header__brand {
    gap: 0.48rem;
    min-height: 2rem;
  }

  :global(.spotlight-header__brand-icon) {
    color: color-mix(in srgb, var(--accent) 72%, var(--muted));
    opacity: 0.82;
  }

  .spotlight-header__link {
    gap: 0.38rem;
    min-height: 2rem;
  }

  :global(.spotlight-header__nav-icon) {
    opacity: 0.5;
    transition:
      opacity var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  .spotlight-header__link:hover :global(.spotlight-header__nav-icon),
  .spotlight-header__link.font-semibold :global(.spotlight-header__nav-icon) {
    opacity: 0.82;
    transform: translateY(-1px);
  }

  .spotlight-header__theme-toggle {
    gap: 0.38rem;
    min-height: 2.75rem;
    padding-inline: 0.85rem;
  }

  .spotlight-header__button {
    transition:
      color var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  :global(.spotlight-header__theme-icon) {
    color: color-mix(in srgb, var(--accent) 70%, var(--muted));
    opacity: 0.78;
  }

  :global(.dark) :global(.spotlight-header__theme-icon--dark),
  :global(html:not(.dark)) :global(.spotlight-header__theme-icon--light) {
    display: none;
  }

  .spotlight-header--inverse .spotlight-header__bar {
    border-color: rgba(255, 255, 255, 0.08) !important;
  }

  .spotlight-header--inverse .spotlight-header__brand,
  .spotlight-header--inverse .spotlight-header__link,
  .spotlight-header--inverse .spotlight-header__button {
    color: rgba(248, 250, 252, 0.94) !important;
  }

  .spotlight-header--inverse :global(.spotlight-header__brand-icon),
  .spotlight-header--inverse :global(.spotlight-header__theme-icon) {
    color: rgba(245, 158, 11, 0.78);
  }

  .spotlight-header--inverse .muted {
    color: rgba(195, 203, 214, 0.72);
  }

  .spotlight-header--inverse .spotlight-header__button {
    border-color: rgba(255, 255, 255, 0.12) !important;
  }

  .spotlight-header--inverse .spotlight-header__menu {
    background: #0c1118;
    border-color: rgba(255, 255, 255, 0.08) !important;
  }

  .spotlight-header--inverse .spotlight-header__menu-link:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .spotlight-header__menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.75rem;
    min-height: 2.75rem;
  }

  .spotlight-header__menu-toggle::-webkit-details-marker {
    display: none;
  }

  .spotlight-header__menu-shell {
    z-index: 50;
  }

  .spotlight-header__menu {
    z-index: 50;
    transform-origin: top right;
    animation: menu-reveal var(--duration-fast) var(--ease-out-quart);
  }

  .spotlight-header__menu-link {
    min-height: 2.75rem;
  }

  .spotlight-header__menu-link[aria-current='page'] {
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    font-weight: 600;
  }

  .spotlight-header__menu-shell[open] .spotlight-header__menu-toggle {
    border-color: color-mix(in srgb, var(--accent) 44%, var(--line)) !important;
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }

  @keyframes menu-reveal {
    from {
      opacity: 0;
      transform: translateY(-0.35rem) scale(0.98);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (hover: hover) {
    .spotlight-header__button:hover {
      transform: translateY(-1px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .spotlight-header__menu {
      animation: none;
    }
  }
</style>
