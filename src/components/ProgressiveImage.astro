---
export interface Props {
  src: string;
  alt: string;
  class?: string;
  lowSrc?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'sync' | 'async' | 'auto';
  sizes?: string;
  width?: number | string;
  height?: number | string;
  style?: string;
  fetchpriority?: 'high' | 'low' | 'auto';
  srcset?: string;
}

const {
  src,
  alt,
  class: className = '',
  lowSrc,
  loading = 'lazy',
  decoding = 'async',
  sizes,
  width,
  height,
  style,
  fetchpriority,
  srcset,
} = Astro.props;

function resolveLowResSource(imageSrc: string) {
  if (!imageSrc) return '/img/photo-placeholder.svg';

  try {
    const parsed = new URL(imageSrc, 'https://placeholder.local');
    const isRemote = /^https?:\/\//.test(imageSrc);

    if (parsed.hostname.includes('images.unsplash.com')) {
      parsed.searchParams.set('w', '64');
      parsed.searchParams.set('q', '20');
      parsed.searchParams.set('auto', 'format');
      parsed.searchParams.set('fit', 'max');
      return parsed.toString();
    }

    if (parsed.hostname.includes('res.cloudinary.com')) {
      return imageSrc.replace('/upload/', '/upload/f_auto,q_20,w_80/');
    }

    if (!isRemote) {
      return '/img/photo-placeholder.svg';
    }
  } catch {
    // Fallback handled below.
  }

  return '/img/photo-placeholder.svg';
}

const placeholderSrc = lowSrc || resolveLowResSource(src);

function resolveResponsiveSrcSet(imageSrc: string) {
  try {
    const parsed = new URL(imageSrc);
    const widths = [480, 768, 1200, 1600];

    if (parsed.hostname.includes('images.unsplash.com')) {
      return widths.map((candidateWidth) => {
        const candidate = new URL(parsed);
        candidate.searchParams.set('w', String(candidateWidth));
        candidate.searchParams.set('q', candidateWidth <= 768 ? '76' : '80');
        candidate.searchParams.set('auto', 'format');
        return `${candidate.toString()} ${candidateWidth}w`;
      }).join(', ');
    }

    if (parsed.hostname.includes('res.cloudinary.com') && imageSrc.includes('/upload/')) {
      return widths.map((candidateWidth) => (
        `${imageSrc.replace('/upload/', `/upload/f_auto,q_auto,w_${candidateWidth}/`)} ${candidateWidth}w`
      )).join(', ');
    }
  } catch {
    // Local assets and unrecognized remote sources use the original URL.
  }

  return undefined;
}

const responsiveSrcSet = srcset || resolveResponsiveSrcSet(src);
---

<span class={`progressive-image ${className}`} data-progressive-image>
  <img src={placeholderSrc} alt="" aria-hidden="true" class="progressive-image__low" loading={loading} decoding="async" fetchpriority="low" />
  <img
    src={src}
    srcset={responsiveSrcSet}
    alt={alt}
    class="progressive-image__high"
    loading={loading}
    decoding={decoding}
    sizes={sizes}
    width={width}
    height={height}
    style={style}
    fetchpriority={fetchpriority}
    onload="this.closest('[data-progressive-image]')?.classList.add('is-loaded')"
  />
</span>

<style>
  .progressive-image {
    position: relative;
    display: block;
    overflow: hidden;
  }

  .progressive-image__low,
  .progressive-image__high {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .progressive-image__low {
    position: absolute;
    inset: 0;
    filter: blur(10px);
    transform: scale(1.025);
    opacity: 1;
    transition: opacity var(--duration-base) var(--ease-standard);
  }

  .progressive-image__high {
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-standard);
  }

  @media (prefers-reduced-motion: reduce) {
    .progressive-image__low,
    .progressive-image__high {
      transition: none;
    }
  }

  .progressive-image.is-loaded .progressive-image__high {
    opacity: 1;
  }

  .progressive-image.is-loaded .progressive-image__low {
    opacity: 0;
  }
</style>
