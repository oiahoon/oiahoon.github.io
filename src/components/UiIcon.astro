  )}
  {name === 'image' && (
    <>
      <path d="M4.75 6.25h14.5v11.5H4.75z" />
      <circle cx="9" cy="10" r="1.25" />
      <path d="M5.5 16.5l4.1-4.1 2.75 2.75 1.8-1.8 4.35 4.35" />
    </>
  )}
  {name === 'arrowLeft' && (
    <>
      <path d="M19 12H5" />
      <path d="M11 6l-6 6 6 6" />
    </>
  )}
  {name === 'arrowRight' && (
    <>
      <path d="M5 12h14" />
