      <path d="M6.5 12h11" />
      <path d="M6.5 16h11" />
    </>
  )}
  {name === 'exif' && (
    <>
      <circle cx="12" cy="12" r="7.25" />
      <path d="M12 8.25v3.9" />
      <path d="M12 15.75h.01" />
      <path d="M16.4 9.2l-1.5 1" />
      <path d="M7.6 9.2l1.5 1" />
