---
import {
  faArrowLeft,
  faArrowRight,
  faBars,
  faBookOpen,
  faBoxArchive,
  faCalendarDays,
  faCameraRetro,
  faCircleInfo,
  faCompass,
  faFileLines,
  faImage,
  faMoon,
  faRss,
  faSun,
  faTag,
  faUser,
  faWandMagicSparkles,
  type IconDefinition,
} from '@fortawesome/free-solid-svg-icons';

export interface Props {
  name:
    | 'article'
    | 'camera'
    | 'tag'
    | 'about'
    | 'notebook'
    | 'spark'
    | 'sun'
    | 'moon'
    | 'archive'
    | 'calendar'
    | 'image'
    | 'arrowLeft'
    | 'arrowRight'
    | 'compass'
    | 'rss'
    | 'menu'
    | 'exif';
  size?: number;
  class?: string;
  decorative?: boolean;
}

const iconMap: Record<Props['name'], IconDefinition> = {
  article: faFileLines,
  camera: faCameraRetro,
  tag: faTag,
  about: faUser,
  notebook: faBookOpen,
  spark: faWandMagicSparkles,
  sun: faSun,
  moon: faMoon,
  archive: faBoxArchive,
  calendar: faCalendarDays,
  image: faImage,
  arrowLeft: faArrowLeft,
  arrowRight: faArrowRight,
  compass: faCompass,
  rss: faRss,
  menu: faBars,
  exif: faCircleInfo,
};

const { name, size = 16, class: className = '', decorative = true } = Astro.props;
const icon = iconMap[name];
const [width, height, , , svgPathData] = icon.icon;
const ariaHidden = decorative ? 'true' : undefined;
const pathData = Array.isArray(svgPathData) ? svgPathData : [svgPathData];
---

<svg
  class={`ui-icon ui-icon--fa ${className}`}
  width={size}
  height={size}
  viewBox={`0 0 ${width} ${height}`}
  fill="currentColor"
  aria-hidden={ariaHidden}
  focusable="false"
>
  {pathData.map((path) => <path d={path} />)}
</svg>
