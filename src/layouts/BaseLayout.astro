---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { generateWebsiteStructuredData } from '../utils/seo';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: 'zh' | 'en';
  structuredData?: string;
  themeMode?: 'system' | 'locked-dark';
}

const { title, description, image, lang = 'zh', structuredData, themeMode = 'system' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Default description for better SEO
const defaultDescription = "黄药师的个人技术博客 - 分享软件开发经验、技术心得和摄影作品";
const cleanTitle = String(title || '').trim();
const seoTitle = cleanTitle && !['undefined', 'null'].includes(cleanTitle.toLowerCase())
  ? cleanTitle
  : "Joey's Notes";
const cleanDescription = String(description || '').trim();
const seoDescription = cleanDescription && !['undefined', 'null'].includes(cleanDescription.toLowerCase())
  ? cleanDescription
  : defaultDescription;

// Generate website structured data for homepage
const websiteStructuredData = Astro.url.pathname === '/' ? generateWebsiteStructuredData() : null;
---

<!DOCTYPE html>
<html lang={lang} class="h-full antialiased" data-theme-mode={themeMode}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/icons/512.png" />
  
  <link rel="canonical" href={canonicalURL} />
  
  <title>{seoTitle}</title>
  <meta name="description" content={seoDescription} />
  <meta name="generator" content={Astro.generator} />
  <meta name="author" content="Joey" />
  <meta name="robots" content="index, follow" />
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={seoTitle} />
  <meta property="og:description" content={seoDescription} />
  <meta property="og:site_name" content="Joey's Notes" />
  <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
  {image && <meta property="og:image" content={new URL(image, Astro.site)} />}
  {image && <meta property="og:image:alt" content={seoTitle} />}
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={seoTitle} />
  <meta name="twitter:description" content={seoDescription} />
  <meta name="twitter:creator" content="@oiahoon" />
  {image && <meta name="twitter:image" content={new URL(image, Astro.site)} />}
  
  <!-- Structured Data -->
  {websiteStructuredData && (
    <script type="application/ld+json" set:html={websiteStructuredData}></script>
  )}
  {structuredData && (
    <script type="application/ld+json" set:html={structuredData}></script>
  )}
  
  <!-- PWA -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#f97316" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="Joey's Notes" />
  <ClientRouter />
  <script is:inline>
    (function () {
      const storageKey = 'theme';
      const darkQuery = window.matchMedia('(prefers-color-scheme: dark)');
      const mode = document.documentElement.dataset.themeMode || 'system';
      const savedTheme = localStorage.getItem(storageKey);
      const theme = mode === 'locked-dark'
        ? 'dark'
        : (savedTheme || (darkQuery.matches ? 'dark' : 'light'));
      document.documentElement.dataset.theme = theme;
      document.documentElement.classList.toggle('dark', theme === 'dark');

      const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
      if (!connection) return;

      const slowNetwork =
        connection.saveData === true ||
        connection.effectiveType === 'slow-2g' ||
        connection.effectiveType === '2g' ||
        (typeof connection.downlink === 'number' && connection.downlink > 0 && connection.downlink < 1.2);

      if (slowNetwork) {
        document.documentElement.classList.add('slow-network', 'content-pending');
      }
    })();
  </script>
  
</head>
<body class="h-full">
  <div class="w-full page-root">
    <slot />
  </div>
  
  <!-- Service Worker Registration -->
  <script>
    (() => {
      const storageKey = 'theme';
      const themeColorMeta = document.querySelector('meta[name="theme-color"]');
      const darkQuery = window.matchMedia('(prefers-color-scheme: dark)');

      function resolveTheme(mode = document.documentElement.dataset.themeMode || 'system') {
        if (mode === 'locked-dark') return 'dark';
        const savedTheme = localStorage.getItem(storageKey);
        return savedTheme || (darkQuery.matches ? 'dark' : 'light');
      }

      function updateThemeUi(theme) {
        document.documentElement.dataset.theme = theme;
        document.documentElement.classList.toggle('dark', theme === 'dark');
        if ((document.documentElement.dataset.themeMode || 'system') !== 'locked-dark') {
          localStorage.setItem(storageKey, theme);
        }
        if (themeColorMeta) {
          themeColorMeta.setAttribute('content', theme === 'dark' ? '#080c12' : '#f97316');
        }
        document.querySelectorAll('[data-theme-toggle-label]').forEach((node) => {
          node.textContent = theme === 'dark' ? '浅色' : '深色';
        });
      }

      function currentTheme() {
        return document.documentElement.classList.contains('dark') ? 'dark' : 'light';
      }

      function bindThemeToggles() {
        document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
          if (button.dataset.themeBound === 'true') return;
          button.dataset.themeBound = 'true';
          button.addEventListener('click', () => {
            if ((document.documentElement.dataset.themeMode || 'system') === 'locked-dark') return;
            updateThemeUi(currentTheme() === 'dark' ? 'light' : 'dark');
          });
        });

        updateThemeUi(resolveTheme());
      }

      bindThemeToggles();
      document.addEventListener('astro:after-swap', () => updateThemeUi(resolveTheme()));
      document.addEventListener('astro:page-load', bindThemeToggles);
    })();

    if ('serviceWorker' in navigator) {
      let refreshing = false;

      window.addEventListener('load', () => {
        document.documentElement.classList.remove('content-pending');

        navigator.serviceWorker.register('/sw.js', { updateViaCache: 'none' })
          .then((registration) => {
            // Periodically check for new service worker after deployments.
            setInterval(() => {
              registration.update();
            }, 60 * 60 * 1000);

            if (registration.waiting) {
              registration.waiting.postMessage({ type: 'SKIP_WAITING' });
            }

            registration.addEventListener('updatefound', () => {
              const newWorker = registration.installing;
              newWorker?.addEventListener('statechange', () => {
                if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                  newWorker.postMessage({ type: 'SKIP_WAITING' });
                }
              });
            });

            navigator.serviceWorker.addEventListener('controllerchange', () => {
              if (refreshing) return;
              refreshing = true;
              window.location.reload();
            });
          })
          .catch(() => {
            // Service worker registration failure should not block page usage.
          });
      });
    } else {
      window.addEventListener('load', () => {
        document.documentElement.classList.remove('content-pending');
      });
    }
  </script>
</body>
</html>
