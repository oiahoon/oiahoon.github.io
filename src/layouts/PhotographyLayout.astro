---
import BaseLayout from './BaseLayout.astro';
import ProgressiveImage from '../components/ProgressiveImage.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  author: string;
  date: Date;
  tags: string[];
  header_img?: string;
  description?: string;
  lang: 'zh' | 'en';
  gallery?: Array<{ src: string; alt?: string; caption?: string; width?: number; height?: number }>;
  camera?: { model?: string; lens?: string; settings?: string };
  location?: string;
  publishedDate?: string;
  previousPhoto?: { slug: string; title?: string; date: Date; image?: string };
  nextPhoto?: { slug: string; title?: string; date: Date; image?: string };
}

const { title, subtitle, date, tags, header_img, description, lang, gallery, camera, location, publishedDate, previousPhoto, nextPhoto } = Astro.props;
const cover = header_img || gallery?.[0]?.src;
const heroPhoto = gallery?.[0];
const galleryPhotos = heroPhoto ? gallery.slice(1) : gallery ?? [];
const allPhotos = heroPhoto ? [heroPhoto, ...galleryPhotos] : galleryPhotos;
const totalPhotos = heroPhoto ? galleryPhotos.length + 1 : galleryPhotos.length;
const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();

const navigation = [
  { name: '文章', href: '/articles/' },
  { name: '摄影', href: '/photography/' },
  { name: '标签', href: '/tags/' },
  { name: '关于', href: '/about/' },
];
---

<BaseLayout title={`${title} | Joey's Notes`} description={description || subtitle || title} image={cover} lang={lang}>
  <article
    class="photo-page"
    id="top"
    data-photo-gallery={JSON.stringify(allPhotos.map((photo, index) => ({
      src: photo.src,
      alt: photo.alt || `照片 ${index + 1}`,
      caption: photo.caption || '',
      index: index + 1,
    })))}
  >
    <section class="photo-stage">
      <header class="photo-topbar">
        <div class="photo-topbar__inner">
          <a href="/" class="photo-topbar__brand">Joey's Notes</a>

          <nav class="photo-topbar__nav" aria-label="主导航">
            {navigation.map((item) => {
              const active = currentPath === item.href || (item.href === '/photography/' && currentPath.startsWith('/posts/'));
              return (
                <a href={item.href} class={`photo-topbar__link ${active ? 'is-active' : ''}`}>
                  {item.name}
                </a>
              );
            })}
          </nav>

          <button
            type="button"
            id="photo-theme-toggle"
            class="photo-topbar__toggle"
            aria-label="切换主题"
          >
            主题
          </button>
        </div>
      </header>

      {heroPhoto && (
        <section class="photo-hero" id="photo-1" data-photo-panel data-photo-index="1">
          <div class="photo-hero__frame">
            <ProgressiveImage
              src={heroPhoto.src}
              alt={heroPhoto.alt || title || '摄影作品'}
              class="photo-hero__image"
              loading="eager"
              decoding="async"
            />
            <button
              type="button"
              class="photo-hero__viewer-trigger"
              data-open-lightbox
              data-photo-index="1"
              aria-label={`全屏查看第 1 张照片${title ? `：${title}` : ''}`}
            ></button>
            <div class="photo-hero__veil"></div>
          </div>

          <div class="photo-hero__overlay photo-hero__overlay--top">
            <div class="photo-hero__topbar">
              <a href="/photography/" class="photo-hero__back">← 返回摄影列表</a>
              <div class="photo-hero__controls">
                {totalPhotos > 1 && (
                  <span class="photo-hero__index">01 / {String(totalPhotos).padStart(2, '0')}</span>
                )}
                {totalPhotos > 1 && (
                  <a href="#photo-2" class="photo-hero__jump">
                    <span>下一张</span>
                    <span aria-hidden="true">↓</span>
                  </a>
                )}
              </div>
            </div>
          </div>

          <div class="photo-hero__overlay photo-hero__overlay--bottom">
            <div class="photo-hero__caption">
              <p class="photo-hero__date">
                {date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}
                {location ? ` · ${location}` : ''}
                {publishedDate ? ` · 发布于 ${publishedDate}` : ''}
              </p>
              {title && <h1 class="photo-hero__title">{title}</h1>}
              {subtitle && <p class="photo-hero__subtitle">{subtitle}</p>}
            </div>

            <div class="photo-hero__info" aria-label="拍摄信息">
              <p class="photo-hero__eyebrow">拍摄信息</p>
              <div class="photo-hero__specs">
                {camera?.model && <p><span>相机</span>{camera.model}</p>}
                {camera?.lens && <p><span>镜头</span>{camera.lens}</p>}
                {camera?.settings && <p><span>参数</span>{camera.settings}</p>}
                {!camera?.model && !camera?.lens && !camera?.settings && <p><span>信息</span>暂无拍摄参数</p>}
              </div>

              {tags.length > 0 && (
                <div class="photo-hero__tags">
                  {tags.map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        </section>
      )}

      {totalPhotos > 1 && (
        <nav class="photo-rail" aria-label="作品内照片导航">
          <div class="photo-rail__inner">
            {allPhotos.map((photo, index) => (
              <a href={`#photo-${index + 1}`} class="photo-rail__item" data-photo-link data-photo-target={String(index + 1)}>
                <img
                  src={photo.src}
                  alt={photo.alt || `照片 ${index + 1}`}
                  class="photo-rail__thumb"
                  loading="lazy"
                  decoding="async"
                />
                <span class="photo-rail__label">{String(index + 1).padStart(2, '0')}</span>
              </a>
            ))}
          </div>
        </nav>
      )}

      {galleryPhotos.length > 0 && (
        <section class="photo-gallery" id="photo-gallery">
          <div class="photo-gallery__stack">
            {galleryPhotos.map((photo, index) => (
              <figure class="photo-gallery__item" id={`photo-${index + 2}`} data-photo-panel data-photo-index={String(index + 2)}>
                <div class="photo-gallery__frame">
                  <ProgressiveImage
                    src={photo.src}
                    alt={photo.alt || `Photo ${index + 2}`}
                    class="photo-gallery__image"
                    loading={index < 1 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                  <button
                    type="button"
                    class="photo-gallery__viewer-trigger"
                    data-open-lightbox
                    data-photo-index={String(index + 2)}
                    aria-label={`全屏查看第 ${index + 2} 张照片`}
                  ></button>
                </div>
                {photo.caption && <figcaption class="photo-gallery__caption">{photo.caption}</figcaption>}
              </figure>
            ))}
          </div>

          <div class="photo-gallery__footer-nav" id="photo-gallery-end">
            <a href="#top" class="photo-gallery__jump">
              <span>回到顶部</span>
              <span aria-hidden="true">↑</span>
            </a>
            <a href="#photo-1" class="photo-gallery__jump">
              <span>回到首张</span>
              <span aria-hidden="true">↑</span>
            </a>
          </div>
        </section>
      )}

      <section class="photo-notes">
        <div class="photo-notes__body prose prose-lg">
          <slot />
        </div>
      </section>

      {(previousPhoto || nextPhoto) && (
        <nav class="photo-post-nav" aria-label="摄影作品分页导航">
          <div class="photo-post-nav__inner">
            {previousPhoto ? (
              <a href={`/posts/${previousPhoto.slug}/`} class="photo-post-nav__link">
                {previousPhoto.image && <img src={previousPhoto.image} alt={previousPhoto.title || '较新作品预览'} class="photo-post-nav__thumb" loading="lazy" decoding="async" />}
                <span class="photo-post-nav__meta">← 较新作品</span>
                <span class="photo-post-nav__title">{previousPhoto.title || previousPhoto.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}</span>
                <span class="photo-post-nav__date">{previousPhoto.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}</span>
              </a>
            ) : (
              <span class="photo-post-nav__link is-empty"></span>
            )}

            {nextPhoto ? (
              <a href={`/posts/${nextPhoto.slug}/`} class="photo-post-nav__link photo-post-nav__link--align-end">
                {nextPhoto.image && <img src={nextPhoto.image} alt={nextPhoto.title || '较早作品预览'} class="photo-post-nav__thumb" loading="lazy" decoding="async" />}
                <span class="photo-post-nav__meta">较早作品 →</span>
                <span class="photo-post-nav__title">{nextPhoto.title || nextPhoto.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}</span>
                <span class="photo-post-nav__date">{nextPhoto.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}</span>
              </a>
            ) : (
              <span class="photo-post-nav__link is-empty"></span>
            )}
          </div>
        </nav>
      )}

      <div class="photo-lightbox" data-photo-lightbox hidden aria-hidden="true">
        <button type="button" class="photo-lightbox__close" data-lightbox-close aria-label="关闭全屏查看">关闭</button>
        <button type="button" class="photo-lightbox__nav photo-lightbox__nav--prev" data-lightbox-prev aria-label="查看上一张">←</button>
        <div class="photo-lightbox__stage">
          <img src="" alt="" class="photo-lightbox__image" data-lightbox-image />
          <div class="photo-lightbox__meta">
            <p class="photo-lightbox__counter" data-lightbox-counter></p>
            <p class="photo-lightbox__caption" data-lightbox-caption></p>
            <div class="photo-lightbox__thumbs" data-lightbox-thumbs></div>
          </div>
        </div>
        <button type="button" class="photo-lightbox__nav photo-lightbox__nav--next" data-lightbox-next aria-label="查看下一张">→</button>
      </div>

      <footer class="photo-footer">
        <div class="photo-footer__inner">
          <div class="photo-footer__grid">
            <section>
              <p class="photo-footer__title">Joey's Notes</p>
              <p class="photo-footer__copy">记录软件工程实践与摄影观察，保持长期、可复用、可查阅的写作习惯。</p>
            </section>

            <section>
              <p class="photo-footer__title">导航</p>
              <div class="photo-footer__links">
                <a href="/articles/">文章</a>
                <a href="/photography/">摄影</a>
                <a href="/tags/">标签</a>
                <a href="/about/">关于</a>
              </div>
            </section>

            <section>
              <p class="photo-footer__title">订阅与链接</p>
              <div class="photo-footer__links">
                <a href="/rss.xml">RSS 订阅</a>
                <a href="https://github.com/oiahoon" target="_blank" rel="noopener noreferrer">GitHub</a>
                <a href="https://weibo.com/desiver" target="_blank" rel="noopener noreferrer">微博</a>
              </div>
            </section>
          </div>

          <div class="photo-footer__meta">© {year} Joey's Notes</div>
        </div>
      </footer>
    </section>
  </article>
</BaseLayout>

<style>
  .photo-page {
    min-height: 100vh;
    background: #05070b;
    color: #eef2f7;
  }

  .photo-stage {
    width: 100%;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.05), transparent 22%),
      linear-gradient(180deg, #05070b 0%, #070a10 58%, #080c12 100%);
  }

  .photo-topbar {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(4, 6, 10, 0.78);
    backdrop-filter: blur(10px);
    transition: background 0.25s ease, border-color 0.25s ease, backdrop-filter 0.25s ease;
  }

  .photo-topbar.is-quiet {
    border-bottom-color: rgba(255, 255, 255, 0.04);
    background: rgba(4, 6, 10, 0.38);
    backdrop-filter: blur(4px);
  }

  .photo-topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(100%, 100rem);
    margin-inline: auto;
    padding: 1rem clamp(1rem, 3vw, 2rem);
  }

  .photo-topbar__brand {
    font-size: 1.05rem;
    font-weight: 600;
    color: rgba(248, 250, 252, 0.96);
  }

  .photo-topbar__nav {
    display: none;
    align-items: center;
    gap: 1.6rem;
  }

  .photo-topbar__link {
    position: relative;
    color: rgba(226, 232, 240, 0.7);
    font-size: 0.94rem;
    transition: color 0.2s ease;
  }

  .photo-topbar__link.is-active,
  .photo-topbar__link:hover {
    color: #f8fafc;
  }

  .photo-topbar__link.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.4rem;
    height: 1px;
    background: rgba(245, 158, 11, 0.8);
  }

  .photo-topbar__toggle {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    padding: 0.5rem 0.95rem;
    background: transparent;
    color: rgba(248, 250, 252, 0.9);
    font-size: 0.8rem;
    cursor: pointer;
  }

  .photo-hero {
    position: relative;
    min-height: calc(100vh - 4.4rem);
    background: #05070b;
  }

  .photo-hero__frame {
    position: relative;
    min-height: calc(100vh - 4.4rem);
  }

  .photo-hero__viewer-trigger,
  .photo-gallery__viewer-trigger {
    position: absolute;
    inset: 0;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: zoom-in;
  }

  .photo-hero__viewer-trigger {
    z-index: 1;
  }

  .photo-hero__image {
    width: 100%;
    height: calc(100vh - 4.4rem);
    object-fit: cover;
    object-position: center;
  }

  .photo-hero__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(5, 7, 11, 0.52) 0%, rgba(5, 7, 11, 0.14) 22%, rgba(5, 7, 11, 0.06) 48%, rgba(5, 7, 11, 0.58) 100%),
      linear-gradient(90deg, rgba(5, 7, 11, 0.2) 0%, transparent 20%, transparent 78%, rgba(5, 7, 11, 0.18) 100%);
    pointer-events: none;
  }

  .photo-hero__overlay {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 2;
    width: min(100%, 100rem);
    margin-inline: auto;
    padding-inline: clamp(1rem, 3vw, 2rem);
  }

  .photo-hero__overlay--top {
    top: 1.35rem;
  }

  .photo-hero__topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .photo-hero__controls {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .photo-hero__overlay--bottom {
    bottom: 0;
    display: grid;
    gap: 1rem;
    align-items: end;
    padding-bottom: clamp(1.25rem, 3vw, 2rem);
  }

  .photo-hero__back {
    display: inline-flex;
    align-items: center;
    color: rgba(245, 247, 250, 0.92);
    font-size: 0.94rem;
    letter-spacing: 0.01em;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
  }

  .photo-hero__index {
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.62);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
  }

  .photo-hero__jump,
  .photo-gallery__jump {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.5rem;
    padding: 0.7rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    background: rgba(5, 7, 11, 0.22);
    backdrop-filter: blur(8px);
    color: rgba(245, 247, 250, 0.86);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
  }

  .photo-hero__caption,
  .photo-hero__info {
    max-width: 100%;
    color: rgba(248, 250, 252, 0.94);
    text-shadow: 0 2px 22px rgba(0, 0, 0, 0.6);
  }

  .photo-hero__date {
    margin: 0;
    font-size: 0.84rem;
    letter-spacing: 0.04em;
    color: rgba(226, 232, 240, 0.78);
  }

  .photo-hero__title {
    margin: 0.65rem 0 0;
    font-size: clamp(2.3rem, 4.8vw, 5rem);
    line-height: 0.98;
    color: #f8fafc;
  }

  .photo-hero__subtitle {
    margin: 0.8rem 0 0;
    max-width: 38rem;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(230, 236, 242, 0.82);
  }

  .photo-hero__eyebrow {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.66);
  }

  .photo-hero__specs {
    margin-top: 0.7rem;
    display: grid;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: rgba(245, 247, 250, 0.92);
  }

  .photo-hero__specs p {
    margin: 0;
    display: grid;
    gap: 0.16rem;
  }

  .photo-hero__specs span {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.62);
  }

  .photo-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.95rem;
  }

  .photo-hero__tags span {
    font-size: 0.74rem;
    color: rgba(232, 238, 243, 0.78);
  }

  .photo-gallery {
    padding: 2.5rem 0 5rem;
  }

  .photo-rail {
    position: relative;
    z-index: 3;
    width: min(100%, 100rem);
    margin: 0 auto;
    padding: 1.25rem clamp(1rem, 3vw, 2rem) 0;
  }

  .photo-rail__inner {
    display: flex;
    gap: 0.8rem;
    overflow-x: auto;
    padding-bottom: 0.4rem;
    scrollbar-width: none;
  }

  .photo-rail__inner::-webkit-scrollbar {
    display: none;
  }

  .photo-rail__item {
    display: grid;
    gap: 0.5rem;
    min-width: 4.6rem;
    color: rgba(226, 232, 240, 0.68);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .photo-rail__item.is-active {
    color: rgba(248, 250, 252, 0.96);
    transform: translateY(-1px);
  }

  .photo-rail__thumb {
    width: 4.6rem;
    height: 5.8rem;
    border-radius: 0.8rem;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    transition: border-color 0.2s ease, transform 0.2s ease, opacity 0.2s ease;
  }

  .photo-rail__item.is-active .photo-rail__thumb {
    border-color: rgba(255, 255, 255, 0.36);
    transform: scale(1.03);
  }

  .photo-rail__label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-align: center;
  }

  .photo-gallery__stack {
    display: grid;
    gap: 3rem;
    width: min(100%, 110rem);
    margin-inline: auto;
    padding-inline: clamp(0.75rem, 2vw, 1.5rem);
  }

  .photo-gallery__item {
    margin: 0;
  }

  .photo-gallery__frame {
    position: relative;
    display: flex;
    min-height: min(90vh, 62rem);
    align-items: center;
    justify-content: center;
  }

  .photo-gallery__image {
    width: 100%;
    max-height: min(90vh, 62rem);
    object-fit: contain;
  }

  .photo-gallery__caption {
    width: min(46rem, calc(100% - 2rem));
    margin: 0.9rem auto 0;
    color: rgba(226, 232, 240, 0.62);
    text-align: center;
    font-size: 0.92rem;
    line-height: 1.8;
  }

  .photo-gallery__footer-nav {
    display: flex;
    justify-content: center;
    gap: 1.4rem;
    padding: 2rem 1rem 0;
  }

  .photo-notes {
    padding: 0 0 5rem;
  }

  .photo-notes__body {
    width: min(46rem, calc(100% - 2rem));
    margin-inline: auto;
    color: rgba(236, 240, 244, 0.9);
  }

  .photo-notes__body :global(p),
  .photo-notes__body :global(li) {
    color: rgba(236, 240, 244, 0.78);
  }

  .photo-post-nav {
    padding: 0 0 4rem;
  }

  .photo-post-nav__inner {
    display: grid;
    gap: 1rem;
    width: min(100%, 96rem);
    margin-inline: auto;
    padding-inline: clamp(1rem, 3vw, 2rem);
  }

  .photo-post-nav__link {
    display: grid;
    gap: 0.45rem;
    padding: 1.15rem 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.1rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0.01));
    color: rgba(245, 247, 250, 0.92);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .photo-post-nav__link:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.14);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.015));
  }

  .photo-post-nav__thumb {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 0.85rem;
    object-fit: cover;
    margin-bottom: 0.3rem;
  }

  .photo-post-nav__link--align-end {
    text-align: right;
  }

  .photo-post-nav__link.is-empty {
    visibility: hidden;
  }

  .photo-post-nav__meta {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(195, 203, 214, 0.58);
  }

  .photo-post-nav__title {
    font-size: 1.06rem;
    line-height: 1.5;
  }

  .photo-post-nav__date {
    font-size: 0.82rem;
    color: rgba(195, 203, 214, 0.62);
  }

  .photo-lightbox[hidden] {
    display: none;
  }

  .photo-lightbox {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: 1.25rem;
    background: rgba(2, 3, 6, 0.92);
    backdrop-filter: blur(14px);
  }

  .photo-lightbox__stage {
    display: grid;
    gap: 1rem;
    justify-items: center;
  }

  .photo-lightbox__image {
    max-width: min(88vw, 110rem);
    max-height: 78vh;
    object-fit: contain;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
  }

  .photo-lightbox__meta {
    width: min(100%, 56rem);
    text-align: center;
  }

  .photo-lightbox__counter {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(195, 203, 214, 0.62);
  }

  .photo-lightbox__caption {
    margin: 0.55rem 0 0;
    color: rgba(236, 240, 244, 0.84);
    line-height: 1.7;
  }

  .photo-lightbox__thumbs {
    display: flex;
    justify-content: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .photo-lightbox__thumb {
    width: 3.9rem;
    height: 4.9rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    padding: 0;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    cursor: pointer;
    opacity: 0.72;
    transition: transform 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
  }

  .photo-lightbox__thumb.is-active {
    border-color: rgba(255, 255, 255, 0.34);
    opacity: 1;
    transform: translateY(-1px);
  }

  .photo-lightbox__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-lightbox__close,
  .photo-lightbox__nav {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(248, 250, 252, 0.92);
    cursor: pointer;
  }

  .photo-lightbox__close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    min-height: 2.6rem;
    padding: 0.7rem 1rem;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .photo-lightbox__nav {
    width: 3rem;
    height: 3rem;
    font-size: 1.1rem;
  }

  .photo-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: #070a10;
  }

  .photo-footer__inner {
    width: min(100%, 96rem);
    margin-inline: auto;
    padding: 3rem clamp(1rem, 3vw, 2rem) 2rem;
  }

  .photo-footer__grid {
    display: grid;
    gap: 2rem;
  }

  .photo-footer__title {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 600;
    color: rgba(248, 250, 252, 0.96);
  }

  .photo-footer__copy {
    max-width: 18rem;
    margin: 0.8rem 0 0;
    font-size: 0.92rem;
    line-height: 1.8;
    color: rgba(195, 203, 214, 0.72);
  }

  .photo-footer__links {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-top: 0.8rem;
  }

  .photo-footer__links a {
    color: rgba(195, 203, 214, 0.72);
    transition: color 0.2s ease;
  }

  .photo-footer__links a:hover {
    color: rgba(248, 250, 252, 0.94);
  }

  .photo-footer__meta {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.78rem;
    color: rgba(195, 203, 214, 0.58);
  }

  @media (min-width: 900px) {
    .photo-topbar__nav {
      display: flex;
    }

    .photo-hero__overlay--bottom {
      grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.72fr);
      gap: 2rem;
    }

    .photo-footer__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .photo-post-nav__inner {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem;
    }

    .photo-rail {
      position: sticky;
      top: 5.6rem;
      margin-top: -8rem;
      pointer-events: none;
    }

    .photo-rail__inner {
      width: fit-content;
      margin-left: auto;
      display: grid;
      gap: 0.7rem;
      overflow: visible;
      pointer-events: auto;
    }

    .photo-rail__item {
      min-width: 0;
    }
  }

  @media (max-width: 720px) {
    .photo-topbar__inner {
      gap: 0.75rem;
    }

    .photo-hero,
    .photo-hero__frame {
      min-height: calc(100svh - 4.4rem);
    }

    .photo-hero__image {
      height: calc(100svh - 4.4rem);
    }

    .photo-hero__overlay--top {
      top: 0.9rem;
    }

    .photo-hero__topbar {
      align-items: flex-start;
      flex-direction: column;
    }

    .photo-hero__controls {
      width: 100%;
      justify-content: space-between;
    }

    .photo-hero__overlay--bottom {
      gap: 0.9rem;
      padding-bottom: 1rem;
    }

    .photo-hero__title {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .photo-hero__subtitle {
      font-size: 0.95rem;
      max-width: 26rem;
    }

    .photo-gallery {
      padding-top: 1.5rem;
    }

    .photo-gallery__frame {
      min-height: 56vh;
    }

    .photo-lightbox {
      grid-template-columns: 1fr;
      padding: 1rem;
      gap: 0.8rem;
    }

    .photo-lightbox__stage {
      margin-top: 2.5rem;
    }

    .photo-lightbox__nav {
      position: absolute;
      bottom: 1rem;
    }

    .photo-lightbox__nav--prev {
      left: 1rem;
    }

    .photo-lightbox__nav--next {
      right: 1rem;
    }
  }
</style>

<script>
  const toggle = document.getElementById('photo-theme-toggle');
  toggle?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
  });

  const galleryRoot = document.querySelector('.photo-page');
  const photoRailLinks = Array.from(document.querySelectorAll('[data-photo-link]'));
  const photoPanels = Array.from(document.querySelectorAll('[data-photo-panel]'));
  const lightbox = document.querySelector('[data-photo-lightbox]');
  const lightboxImage = lightbox?.querySelector('[data-lightbox-image]');
  const lightboxCaption = lightbox?.querySelector('[data-lightbox-caption]');
  const lightboxCounter = lightbox?.querySelector('[data-lightbox-counter]');
  const lightboxClose = lightbox?.querySelector('[data-lightbox-close]');
  const lightboxPrev = lightbox?.querySelector('[data-lightbox-prev]');
  const lightboxNext = lightbox?.querySelector('[data-lightbox-next]');
  const lightboxThumbs = lightbox?.querySelector('[data-lightbox-thumbs]');
  const lightboxTriggers = Array.from(document.querySelectorAll('[data-open-lightbox]'));
  const galleryData = galleryRoot?.getAttribute('data-photo-gallery');
  const photos = galleryData ? JSON.parse(galleryData) : [];
  const topbar = document.querySelector('.photo-topbar');
  let activePhoto = 1;
  let lightboxIndex = 0;

  function syncActiveRail(index) {
    activePhoto = index;
    photoRailLinks.forEach((link) => {
      link.classList.toggle('is-active', Number(link.getAttribute('data-photo-target')) === index);
    });
  }

  if (photoPanels.length && photoRailLinks.length) {
    const observer = new IntersectionObserver((entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

      if (!visible) return;
      const index = Number(visible.target.getAttribute('data-photo-index'));
      if (index) syncActiveRail(index);
    }, { threshold: [0.35, 0.6], rootMargin: '-12% 0px -20% 0px' });

    photoPanels.forEach((panel) => observer.observe(panel));
    syncActiveRail(1);
  }

  function renderLightbox() {
    if (!photos[lightboxIndex] || !lightbox || !lightboxImage || !lightboxCaption || !lightboxCounter) return;
    const current = photos[lightboxIndex];
    lightboxImage.src = current.src;
    lightboxImage.alt = current.alt || '';
    lightboxCaption.textContent = current.caption || '';
    lightboxCounter.textContent = `照片 ${String(lightboxIndex + 1).padStart(2, '0')} / ${String(photos.length).padStart(2, '0')}`;
    if (lightboxThumbs) {
      lightboxThumbs.innerHTML = photos.map((photo, index) => `
        <button
          type="button"
          class="photo-lightbox__thumb ${index === lightboxIndex ? 'is-active' : ''}"
          data-lightbox-thumb="${index}"
          aria-label="查看第 ${index + 1} 张照片"
        >
          <img src="${photo.src}" alt="${photo.alt || `照片 ${index + 1}`}" />
        </button>
      `).join('');

      lightboxThumbs.querySelectorAll('[data-lightbox-thumb]').forEach((thumb) => {
        thumb.addEventListener('click', () => {
          lightboxIndex = Number(thumb.getAttribute('data-lightbox-thumb') || '0');
          renderLightbox();
        });
      });
    }
  }

  function openLightbox(index) {
    if (!lightbox || !photos.length) return;
    lightboxIndex = Math.min(Math.max(index, 0), photos.length - 1);
    renderLightbox();
    lightbox.hidden = false;
    lightbox.setAttribute('aria-hidden', 'false');
    document.documentElement.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.hidden = true;
    lightbox.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
  }

  function stepLightbox(direction) {
    if (!photos.length) return;
    lightboxIndex = (lightboxIndex + direction + photos.length) % photos.length;
    renderLightbox();
  }

  lightboxTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const index = Number(trigger.getAttribute('data-photo-index') || '1') - 1;
      openLightbox(index);
    });
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightboxPrev?.addEventListener('click', () => stepLightbox(-1));
  lightboxNext?.addEventListener('click', () => stepLightbox(1));
  lightbox?.addEventListener('click', (event) => {
    if (event.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (event) => {
    const isOpen = lightbox && !lightbox.hidden;
    if (!isOpen) return;
    if (event.key === 'Escape') closeLightbox();
    if (event.key === 'ArrowLeft') stepLightbox(-1);
    if (event.key === 'ArrowRight') stepLightbox(1);
  });

  function syncTopbarState() {
    if (!topbar) return;
    topbar.classList.toggle('is-quiet', window.scrollY > 120);
  }

  syncTopbarState();
  window.addEventListener('scroll', syncTopbarState, { passive: true });
</script>
