---
import BaseLayout from './BaseLayout.astro';
import ProgressiveImage from '../components/ProgressiveImage.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  author: string;
  date: Date;
  tags: string[];
  header_img?: string;
  description?: string;
  lang: 'zh' | 'en';
  gallery?: Array<{ src: string; alt?: string; caption?: string; width?: number; height?: number }>;
  camera?: { model?: string; lens?: string; settings?: string };
  location?: string;
  publishedDate?: string;
}

const { title, subtitle, date, tags, header_img, description, lang, gallery, camera, location, publishedDate } = Astro.props;
const cover = header_img || gallery?.[0]?.src;
const heroPhoto = gallery?.[0];
const galleryPhotos = heroPhoto ? gallery.slice(1) : gallery ?? [];
const currentPath = Astro.url.pathname;

const navigation = [
  { name: '文章', href: '/articles/' },
  { name: '摄影', href: '/photography/' },
  { name: '标签', href: '/tags/' },
  { name: '关于', href: '/about/' },
];
---

<BaseLayout title={`${title} | Joey's Notes`} description={description || subtitle || title} image={cover} lang={lang}>
  <article class="photo-page">
    <section class="photo-stage">
      <header class="photo-topbar">
        <div class="photo-topbar__inner">
          <a href="/" class="photo-topbar__brand">Joey's Notes</a>

          <nav class="photo-topbar__nav" aria-label="主导航">
            {navigation.map((item) => {
              const active = currentPath === item.href || (item.href === '/photography/' && currentPath.startsWith('/posts/'));
              return (
                <a href={item.href} class={`photo-topbar__link ${active ? 'is-active' : ''}`}>
                  {item.name}
                </a>
              );
            })}
          </nav>

          <button
            type="button"
            id="photo-theme-toggle"
            class="photo-topbar__toggle"
            aria-label="切换主题"
          >
            主题
          </button>
        </div>
      </header>

      {heroPhoto && (
        <section class="photo-hero">
          <div class="photo-hero__frame">
            <ProgressiveImage
              src={heroPhoto.src}
              alt={heroPhoto.alt || title || '摄影作品'}
              class="photo-hero__image"
              loading="eager"
              decoding="async"
            />
          </div>

          <div class="photo-hero__floating photo-hero__floating--top">
            <a href="/photography/" class="photo-hero__back">← 返回摄影列表</a>
          </div>

          <div class="photo-hero__floating photo-hero__floating--bottom">
            <div class="photo-hero__caption">
              <p class="photo-hero__date">
                {date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}
                {location ? ` · ${location}` : ''}
                {publishedDate ? ` · 发布于 ${publishedDate}` : ''}
              </p>
              {title && <h1 class="photo-hero__title">{title}</h1>}
              {subtitle && <p class="photo-hero__subtitle">{subtitle}</p>}
            </div>

            <aside class="photo-hero__info">
              <p class="photo-hero__eyebrow">拍摄信息</p>
              <div class="photo-hero__specs">
                {camera?.model && <p><span>相机</span>{camera.model}</p>}
                {camera?.lens && <p><span>镜头</span>{camera.lens}</p>}
                {camera?.settings && <p><span>参数</span>{camera.settings}</p>}
                {!camera?.model && !camera?.lens && !camera?.settings && <p><span>信息</span>暂无拍摄参数</p>}
              </div>

              {tags.length > 0 && (
                <div class="photo-hero__tags">
                  {tags.map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>
              )}
            </aside>
          </div>
        </section>
      )}

      {galleryPhotos.length > 0 && (
        <section class="photo-gallery">
          <div class="photo-gallery__stack">
            {galleryPhotos.map((photo, index) => (
              <figure class="photo-gallery__item">
                <div class="photo-gallery__frame">
                  <ProgressiveImage
                    src={photo.src}
                    alt={photo.alt || `Photo ${index + 2}`}
                    class="photo-gallery__image"
                    loading={index < 1 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </div>
                {photo.caption && <figcaption class="photo-gallery__caption">{photo.caption}</figcaption>}
              </figure>
            ))}
          </div>
        </section>
      )}

      <section class="photo-notes">
        <div class="photo-notes__body prose prose-lg">
          <slot />
        </div>
      </section>
    </section>
  </article>
</BaseLayout>

<style>
  .photo-page {
    min-height: 100vh;
    background: #05070b;
    color: #eef2f7;
  }

  .photo-stage {
    width: 100%;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 24%),
      linear-gradient(180deg, #090c11, #05070b 24%, #070a10 72%, #0b1017 100%);
  }

  .photo-topbar {
    position: sticky;
    top: 0;
    z-index: 30;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(4, 6, 10, 0.9);
    backdrop-filter: blur(12px);
  }

  .photo-topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(100%, 96rem);
    margin-inline: auto;
    padding: 1rem clamp(1rem, 3vw, 2rem);
  }

  .photo-topbar__brand {
    font-size: 1.05rem;
    font-weight: 600;
    color: #f8fafc;
  }

  .photo-topbar__nav {
    display: none;
    align-items: center;
    gap: 1.6rem;
  }

  .photo-topbar__link {
    position: relative;
    color: rgba(226, 232, 240, 0.66);
    font-size: 0.94rem;
    transition: color 0.2s ease;
  }

  .photo-topbar__link.is-active,
  .photo-topbar__link:hover {
    color: #f8fafc;
  }

  .photo-topbar__link.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.4rem;
    height: 1px;
    background: rgba(245, 158, 11, 0.8);
  }

  .photo-topbar__toggle {
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 9999px;
    padding: 0.5rem 0.95rem;
    background: transparent;
    color: rgba(248, 250, 252, 0.9);
    font-size: 0.8rem;
    cursor: pointer;
  }

  .photo-hero {
    position: relative;
    min-height: calc(100vh - 4.4rem);
    padding: 0;
  }

  .photo-hero__frame {
    display: flex;
    min-height: calc(100vh - 4.4rem);
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .photo-hero__image {
    width: 100%;
    height: calc(100vh - 4.4rem);
    object-fit: contain;
  }

  .photo-hero__floating {
    position: absolute;
    left: 0;
    right: 0;
    width: min(100%, 96rem);
    margin-inline: auto;
    padding-inline: clamp(1rem, 3vw, 2rem);
  }

  .photo-hero__floating--top {
    top: 1.25rem;
  }

  .photo-hero__floating--bottom {
    bottom: 0;
    display: grid;
    gap: 1rem;
    padding-bottom: 1.25rem;
    align-items: end;
  }

  .photo-hero__back,
  .photo-hero__caption,
  .photo-hero__info {
    backdrop-filter: blur(10px);
    background: rgba(5, 7, 11, 0.56);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.28);
  }

  .photo-hero__back {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    padding: 0.7rem 1rem;
    color: rgba(248, 250, 252, 0.92);
    font-size: 0.92rem;
  }

  .photo-hero__caption {
    border-radius: 1.2rem;
    padding: 1rem 1.15rem;
    color: rgba(255, 255, 255, 0.94);
  }

  .photo-hero__date {
    margin: 0;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.66);
  }

  .photo-hero__title {
    margin: 0.7rem 0 0;
    font-size: clamp(2.2rem, 4vw, 4.6rem);
    line-height: 1.02;
    color: #f8fafc;
  }

  .photo-hero__subtitle {
    margin: 0.85rem 0 0;
    max-width: 40rem;
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.76);
  }

  .photo-hero__info {
    border-radius: 1.2rem;
    padding: 1rem 1.15rem;
    color: rgba(255, 255, 255, 0.88);
  }

  .photo-hero__eyebrow {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
  }

  .photo-hero__specs {
    margin-top: 0.8rem;
    display: grid;
    gap: 0.4rem;
    font-size: 0.92rem;
  }

  .photo-hero__specs p {
    margin: 0;
    display: grid;
    gap: 0.2rem;
  }

  .photo-hero__specs span {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.52);
  }

  .photo-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.95rem;
  }

  .photo-hero__tags span {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    padding: 0.35rem 0.7rem;
    font-size: 0.74rem;
    color: rgba(255, 255, 255, 0.72);
  }

  .photo-gallery {
    padding: 0 0 5rem;
  }

  .photo-gallery__stack {
    display: grid;
    gap: 3rem;
    width: min(100%, 110rem);
    margin-inline: auto;
    padding-inline: clamp(0.75rem, 2vw, 1.5rem);
  }

  .photo-gallery__item {
    margin: 0;
  }

  .photo-gallery__frame {
    display: flex;
    min-height: min(90vh, 62rem);
    align-items: center;
    justify-content: center;
  }

  .photo-gallery__image {
    width: 100%;
    max-height: min(90vh, 62rem);
    object-fit: contain;
  }

  .photo-gallery__caption {
    width: min(46rem, calc(100% - 2rem));
    margin: 0.9rem auto 0;
    color: rgba(255, 255, 255, 0.64);
    text-align: center;
    font-size: 0.92rem;
    line-height: 1.8;
  }

  .photo-notes {
    padding: 0 0 5rem;
  }

  .photo-notes__body {
    width: min(46rem, calc(100% - 2rem));
    margin-inline: auto;
    color: rgba(236, 240, 244, 0.9);
  }

  .photo-notes__body :global(p),
  .photo-notes__body :global(li) {
    color: rgba(236, 240, 244, 0.78);
  }

  @media (min-width: 900px) {
    .photo-topbar__nav {
      display: flex;
    }

    .photo-hero__floating--bottom {
      grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.8fr);
    }
  }

  @media (max-width: 720px) {
    .photo-topbar__inner {
      gap: 0.75rem;
    }

    .photo-hero {
      min-height: auto;
    }

    .photo-hero__frame {
      min-height: auto;
      padding-top: 0;
    }

    .photo-hero__image {
      height: auto;
      min-height: 56vh;
    }

    .photo-hero__floating--bottom {
      position: static;
      width: 100%;
      padding: 0.9rem 0.9rem 0;
    }

    .photo-hero__floating--top {
      top: 0.85rem;
    }

    .photo-gallery__frame {
      min-height: 56vh;
    }
  }
</style>

<script>
  const toggle = document.getElementById('photo-theme-toggle');
  toggle?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
  });
</script>
