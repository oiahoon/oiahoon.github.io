---
import BaseLayout from './BaseLayout.astro';
import ProgressiveImage from '../components/ProgressiveImage.astro';
import UiIcon from '../components/UiIcon.astro';

export interface Props {
  slug?: string;
  title?: string;
  subtitle?: string;
  author: string;
  date: Date;
  tags: string[];
  header_img?: string;
  description?: string;
  lang: 'zh' | 'en';
  gallery?: Array<{ src: string; alt?: string; caption?: string; width?: number; height?: number }>;
  camera?: { model?: string; lens?: string; settings?: string };
  location?: string;
  publishedDate?: string;
  previousPhoto?: { slug: string; title?: string; date: Date; image?: string };
  nextPhoto?: { slug: string; title?: string; date: Date; image?: string };
  photoCollection?: Array<{ slug: string; title?: string; date: Date; image?: string; active?: boolean }>;
}

const { slug, title, subtitle, date, tags, header_img, description, lang, gallery, camera, location, publishedDate, previousPhoto, nextPhoto, photoCollection = [] } = Astro.props;
const cover = header_img || gallery?.[0]?.src;
const heroPhoto = gallery?.[0];
const galleryPhotos = heroPhoto ? gallery.slice(1) : gallery ?? [];
const allPhotos = heroPhoto ? [heroPhoto, ...galleryPhotos] : galleryPhotos;
const totalPhotos = heroPhoto ? galleryPhotos.length + 1 : galleryPhotos.length;
const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();
const visibleTags = tags.filter((tag) => tag !== '摄影');
const exifEntries = [
  camera?.model,
  camera?.lens,
  camera?.settings,
].filter(Boolean);
const photoTransitionName = slug ? `photo-cover-${slug}` : undefined;
const fallbackTitle = title || `摄影作品 · ${date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}`;
const activeWorkIndex = Math.max(photoCollection.findIndex((work) => work.active), 0);
const totalWorks = photoCollection.length;

const navigation = [
  { name: 'Photographs', href: '/photography/', icon: 'camera' },
  { name: 'Notes', href: '/articles/', icon: 'article' },
  { name: 'About', href: '/about/', icon: 'about' },
] as const;
---

<BaseLayout title={`${fallbackTitle} | Joey's Notes`} description={description || subtitle || fallbackTitle} image={cover} lang={lang} themeMode="locked-dark">
  <article
    class="photo-page"
    id="top"
    data-photo-gallery={JSON.stringify(allPhotos.map((photo, index) => ({
      src: photo.src,
      alt: photo.alt || `照片 ${index + 1}`,
      caption: photo.caption || '',
      index: index + 1,
    })))}
  >
    <section class="photo-stage">
      <header class="photo-topbar">
        <div class="photo-topbar__inner">
          <a href="/" class="photo-topbar__brand" data-astro-prefetch style="view-transition-name: site-brand;"><UiIcon name="notebook" size={17} /> <span>Joey's Notes</span></a>

          <nav class="photo-topbar__nav" aria-label="主导航">
            {navigation.map((item) => {
              const active = currentPath === item.href || (item.href === '/photography/' && currentPath.startsWith('/posts/'));
              return (
                <a href={item.href} class={`photo-topbar__link ${active ? 'is-active' : ''}`} aria-current={active ? 'page' : undefined} data-astro-prefetch>
                  <UiIcon name={item.icon} size={14} />
                  <span>{item.name}</span>
                </a>
              );
            })}
          </nav>

          <div class="photo-topbar__actions">
            <details class="photo-topbar__menu-shell">
              <summary class="photo-topbar__menu-toggle" aria-label="导航">
                <UiIcon name="menu" size={16} />
              </summary>
              <nav class="photo-topbar__menu" aria-label="移动导航">
                {navigation.map((item) => (
                  <a href={item.href} class={`photo-topbar__menu-link ${currentPath === item.href || (item.href === '/photography/' && currentPath.startsWith('/posts/')) ? 'is-active' : ''}`} aria-current={currentPath === item.href || (item.href === '/photography/' && currentPath.startsWith('/posts/')) ? 'page' : undefined} data-astro-prefetch>
                    <UiIcon name={item.icon} size={14} />
                  <span>{item.name}</span>
                  </a>
                ))}
              </nav>
            </details>
          </div>
        </div>
      </header>

      {heroPhoto && (
        <section class="photo-hero" id="photo-1" data-photo-panel data-photo-index="1">
          <div class="photo-hero__frame">
            <ProgressiveImage
              src={heroPhoto.src}
              alt={heroPhoto.alt || title || '摄影作品'}
              class="photo-hero__image"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              width={heroPhoto.width}
              height={heroPhoto.height}
              sizes="100vw"
              style={photoTransitionName ? `view-transition-name: ${photoTransitionName};` : undefined}
            />
            <button
              type="button"
              class="photo-hero__viewer-trigger"
              data-open-lightbox
              data-photo-index="1"
              aria-label={`全屏查看第 1 张照片${title ? `：${title}` : ''}`}
            ></button>
            <div class="photo-hero__veil"></div>
          </div>

          <div class="photo-hero__overlay photo-hero__overlay--top" data-photo-overlay-top>
            <div class="photo-hero__topbar">
              <a href="/photography/" class="photo-hero__back" data-astro-prefetch><UiIcon name="arrowLeft" size={15} /> <span>返回摄影列表</span></a>
              <div class="photo-hero__controls">
                {totalPhotos > 1 && (
                  <span class="photo-hero__index">01 / {String(totalPhotos).padStart(2, '0')}</span>
                )}
                {totalPhotos > 1 && (
                  <a href="#photo-2" class="photo-hero__jump">
                    <span>下一张</span>
                    <span aria-hidden="true">↓</span>
                  </a>
                )}
              </div>
            </div>
          </div>

          <div class="photo-hero__overlay photo-hero__overlay--bottom" data-photo-overlay-bottom>
            <div class="photo-hero__caption">
              <p class="photo-hero__date">
                {location ? `${location} · ` : ''}
                {date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', { year: 'numeric', month: 'long' })}
              </p>
              {title && <h1 class="photo-hero__title" style={photoTransitionName ? `view-transition-name: photo-title-${slug};` : undefined}>{title}</h1>}
              {(subtitle || heroPhoto.caption) && <p class="photo-hero__subtitle">{subtitle || heroPhoto.caption}</p>}
            </div>

            <details class="photo-hero__info" aria-label="Technical details">
              <summary><UiIcon name="exif" size={14} /> <span>Technical details</span></summary>
              <div class="photo-hero__specs">
                {exifEntries.length > 0 ? (
                  exifEntries.map((entry) => <p>{entry}</p>)
                ) : (
                  <p>暂无 EXIF 信息</p>
                )}
              </div>

              {visibleTags.length > 0 && (
                <div class="photo-hero__tags">
                  {visibleTags.map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>
              )}
            </details>
          </div>
        </section>
      )}

      {totalPhotos > 1 && (
        <nav class="photo-rail" aria-label="作品内照片导航">
          <div class="photo-rail__inner">
            {allPhotos.map((photo, index) => (
              <a href={`#photo-${index + 1}`} class="photo-rail__item" data-photo-link data-photo-target={String(index + 1)}>
                <img
                  src={photo.src}
                  alt={photo.alt || `照片 ${index + 1}`}
                  class="photo-rail__thumb"
                  loading="lazy"
                  decoding="async"
                />
                <span class="photo-rail__label">{String(index + 1).padStart(2, '0')}</span>
              </a>
            ))}
          </div>
        </nav>
      )}

      {galleryPhotos.length > 0 && (
        <section class="photo-gallery" id="photo-gallery">
          <div class="photo-gallery__stack">
            {galleryPhotos.map((photo, index) => (
              <figure class="photo-gallery__item" id={`photo-${index + 2}`} data-photo-panel data-photo-index={String(index + 2)}>
                <div class="photo-gallery__frame">
                  <ProgressiveImage
                    src={photo.src}
                    alt={photo.alt || `Photo ${index + 2}`}
                    class="photo-gallery__image"
                    loading={index < 1 ? 'eager' : 'lazy'}
                    decoding="async"
                    width={photo.width}
                    height={photo.height}
                    sizes="100vw"
                  />
                  <button
                    type="button"
                    class="photo-gallery__viewer-trigger"
                    data-open-lightbox
                    data-photo-index={String(index + 2)}
                    aria-label={`全屏查看第 ${index + 2} 张照片`}
                  ></button>
                </div>
                {photo.caption && <figcaption class="photo-gallery__caption">{photo.caption}</figcaption>}
              </figure>
            ))}
          </div>

          <div class="photo-gallery__footer-nav" id="photo-gallery-end">
            <a href="#top" class="photo-gallery__jump">
              <span>回到顶部</span>
              <span aria-hidden="true">↑</span>
            </a>
            <a href="#photo-1" class="photo-gallery__jump">
              <span>回到首张</span>
              <span aria-hidden="true">↑</span>
            </a>
          </div>
        </section>
      )}

      <section class="photo-notes">
        <div class="photo-notes__body prose prose-lg">
          <slot />
        </div>
      </section>

      {photoCollection.length > 1 && (
        <section class="photo-work-strip" aria-label="更多摄影作品">
          <div class="photo-work-strip__head">
            <div>
              <p class="photo-work-strip__eyebrow"><UiIcon name="image" size={14} /> <span>More from this series</span></p>
              <h2 class="photo-work-strip__title">Continue browsing photographs</h2>
            </div>
            {(previousPhoto || nextPhoto) && (
              <p class="photo-work-strip__hint">
                <span>{String(activeWorkIndex + 1).padStart(2, '0')} / {String(totalWorks).padStart(2, '0')}</span>
                {(previousPhoto || nextPhoto) && <span>·</span>}
                {previousPhoto && <span>← 较新</span>}
                {previousPhoto && nextPhoto && <span>·</span>}
                {nextPhoto && <span>较早 →</span>}
              </p>
            )}
          </div>

          <div class="photo-work-strip__rail" data-work-rail>
            {photoCollection.map((work) => (
              <a
                href={`/posts/${work.slug}/`}
                class={`photo-work-strip__item ${work.active ? 'is-active' : ''}`}
                data-work-link
                data-astro-prefetch
              >
                {work.image && (
                  <img
                    src={work.image}
                    alt={work.title || '摄影作品预览'}
                    class="photo-work-strip__thumb"
                    loading="lazy"
                    decoding="async"
                  />
                )}
                <div class="photo-work-strip__copy">
                  <p class="photo-work-strip__date">{work.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}</p>
                  {work.title && <p class="photo-work-strip__name">{work.title}</p>}
                </div>
              </a>
            ))}
          </div>
          <p class="photo-work-strip__scroll-hint">横向滑动查看更多作品</p>
        </section>
      )}

      <div class="photo-lightbox" data-photo-lightbox hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label="Photo viewer" tabindex="-1">
        <button type="button" class="photo-lightbox__close" data-lightbox-close aria-label="关闭全屏查看">关闭</button>
        <button type="button" class="photo-lightbox__nav photo-lightbox__nav--prev" data-lightbox-prev aria-label="查看上一张">←</button>
        <div class="photo-lightbox__stage">
          <img src="" alt="" class="photo-lightbox__image" data-lightbox-image />
          <div class="photo-lightbox__meta">
            <p class="photo-lightbox__counter" data-lightbox-counter></p>
            <p class="photo-lightbox__caption" data-lightbox-caption></p>
            <div class="photo-lightbox__thumbs" data-lightbox-thumbs></div>
          </div>
        </div>
        <button type="button" class="photo-lightbox__nav photo-lightbox__nav--next" data-lightbox-next aria-label="查看下一张">→</button>
      </div>

      <footer class="photo-footer">
        <div class="photo-footer__inner">
          <div class="photo-footer__grid">
            <section>
              <p class="photo-footer__title">Joey's Notes</p>
              <p class="photo-footer__copy">Photographs, field notes, and a legacy archive of engineering notes.</p>
            </section>

            <section>
              <p class="photo-footer__title">导航</p>
              <div class="photo-footer__links">
                <a href="/photography/" data-astro-prefetch>Photographs</a>
                <a href="/articles/" data-astro-prefetch>Notes</a>
                <a href="/about/" data-astro-prefetch>About</a>
                <a href="/tags/" data-astro-prefetch>Tags</a>
              </div>
            </section>

            <section>
              <p class="photo-footer__title">订阅与链接</p>
              <div class="photo-footer__links">
                <a href="/rss.xml">RSS 订阅</a>
                <a href="https://github.com/oiahoon" target="_blank" rel="noopener noreferrer">GitHub</a>
                <a href="https://weibo.com/desiver" target="_blank" rel="noopener noreferrer">微博</a>
              </div>
            </section>
          </div>

          <div class="photo-footer__meta">© {year} Joey's Notes</div>
        </div>
      </footer>
    </section>
  </article>
</BaseLayout>

<style>
  .photo-page {
    min-height: 100vh;
    background: #05070b;
    color: #eef2f7;
  }

  .photo-stage {
    width: 100%;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.05), transparent 22%),
      linear-gradient(180deg, #05070b 0%, #070a10 58%, #080c12 100%);
  }

  .photo-topbar {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(4, 6, 10, 0.78);
    backdrop-filter: blur(10px);
    transition: background 0.25s ease, border-color 0.25s ease, backdrop-filter 0.25s ease;
  }

  .photo-topbar.is-quiet {
    border-bottom-color: rgba(255, 255, 255, 0.04);
    background: rgba(4, 6, 10, 0.38);
    backdrop-filter: blur(4px);
  }

  .photo-topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(100%, 100rem);
    margin-inline: auto;
    padding: 1rem clamp(1rem, 3vw, 2rem);
  }

  .photo-topbar__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: rgba(248, 250, 252, 0.96);
  }

  .photo-topbar__actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .photo-topbar__nav {
    display: none;
    align-items: center;
    gap: 1.6rem;
  }

  .photo-topbar__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    color: rgba(226, 232, 240, 0.7);
    font-size: 0.94rem;
    transition: color 0.2s ease;
  }

  .photo-topbar__link.is-active,
  .photo-topbar__link:hover {
    color: #f8fafc;
  }

  .photo-topbar__link.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.4rem;
    height: 1px;
    background: rgba(245, 158, 11, 0.8);
  }

  .photo-topbar__toggle {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    padding: 0.5rem 0.95rem;
    background: transparent;
    color: rgba(248, 250, 252, 0.9);
    font-size: 0.8rem;
    cursor: pointer;
  }

  .photo-topbar__menu-shell {
    position: relative;
  }

  .photo-topbar__menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    min-height: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    background: transparent;
    color: rgba(248, 250, 252, 0.9);
    cursor: pointer;
    list-style: none;
  }

  .photo-topbar__menu-toggle::-webkit-details-marker {
    display: none;
  }


  .photo-topbar__menu {
    position: absolute;
    right: 0;
    margin-top: 0.6rem;
    min-width: 9rem;
    padding: 0.45rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    background: rgba(12, 17, 24, 0.96);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(14px);
  }

  .photo-topbar__menu-link {
    display: flex;
    align-items: center;
    gap: 0.48rem;
    padding: 0.65rem 0.85rem;
    border-radius: 0.8rem;
    color: rgba(226, 232, 240, 0.78);
    font-size: 0.92rem;
  }

  .photo-topbar__menu-link.is-active,
  .photo-topbar__menu-link:hover {
    background: rgba(255, 255, 255, 0.06);
    color: rgba(248, 250, 252, 0.96);
  }

  .photo-hero {
    position: relative;
    min-height: calc(100vh - 4.4rem);
    background: #05070b;
  }

  .photo-hero__frame {
    position: relative;
    min-height: calc(100vh - 4.4rem);
  }

  .photo-hero__viewer-trigger,
  .photo-gallery__viewer-trigger {
    position: absolute;
    inset: 0;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: zoom-in;
  }

  .photo-hero__viewer-trigger {
    z-index: 1;
  }

  .photo-hero__image {
    width: 100%;
    height: calc(100vh - 4.4rem);
    object-fit: cover;
    object-position: center;
  }

  .photo-hero__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(5, 7, 11, 0.52) 0%, rgba(5, 7, 11, 0.14) 22%, rgba(5, 7, 11, 0.06) 48%, rgba(5, 7, 11, 0.58) 100%),
      linear-gradient(90deg, rgba(5, 7, 11, 0.2) 0%, transparent 20%, transparent 78%, rgba(5, 7, 11, 0.18) 100%);
    pointer-events: none;
  }

  .photo-hero__overlay {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 2;
    width: min(100%, 100rem);
    margin-inline: auto;
    padding-inline: clamp(1rem, 3vw, 2rem);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .photo-hero__overlay--top {
    top: 1.35rem;
  }

  .photo-hero__overlay--top.is-quiet {
    opacity: 0.62;
    transform: translateY(-4px);
  }

  .photo-hero__topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .photo-hero__controls {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .photo-hero__overlay--bottom {
    bottom: 0;
    display: grid;
    gap: 1rem;
    align-items: end;
    padding-bottom: clamp(1.25rem, 3vw, 2rem);
  }

  .photo-hero__overlay--bottom.is-quiet {
    opacity: 0.72;
    transform: translateY(8px);
  }

  .photo-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    color: rgba(245, 247, 250, 0.92);
    font-size: 0.94rem;
    letter-spacing: 0.01em;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .photo-hero__index {
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.62);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
  }

  .photo-hero__jump,
  .photo-gallery__jump {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.5rem;
    padding: 0.7rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    background: rgba(5, 7, 11, 0.22);
    backdrop-filter: blur(8px);
    color: rgba(245, 247, 250, 0.86);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
    transition: background 0.2s ease, border-color 0.2s ease, opacity 0.2s ease, transform 0.2s ease;
  }

  .photo-hero__caption,
  .photo-hero__info {
    max-width: 100%;
    color: rgba(248, 250, 252, 0.94);
    text-shadow: 0 2px 22px rgba(0, 0, 0, 0.6);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .photo-hero__info {
    align-self: end;
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    padding-top: 0.85rem;
  }

  .photo-hero__info summary {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    color: rgba(226, 232, 240, 0.78);
    font-size: 0.86rem;
    cursor: pointer;
    list-style: none;
  }

  .photo-hero__info summary::-webkit-details-marker {
    display: none;
  }

  .photo-hero__info summary::after {
    content: '+';
    margin-left: 0.4rem;
    color: rgba(226, 232, 240, 0.58);
  }

  .photo-hero__info[open] summary::after {
    content: '-';
  }

  .photo-hero__date {
    margin: 0;
    font-size: 0.84rem;
    letter-spacing: 0.04em;
    color: rgba(226, 232, 240, 0.78);
  }

  .photo-hero__title {
    margin: 0.65rem 0 0;
    font-size: clamp(2.3rem, 4.8vw, 5rem);
    line-height: 0.98;
    color: #f8fafc;
  }

  .photo-hero__subtitle {
    margin: 0.8rem 0 0;
    max-width: 38rem;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(230, 236, 242, 0.82);
  }

  .photo-hero__overlay--bottom.is-quiet .photo-hero__caption,
  .photo-hero__overlay--bottom.is-quiet .photo-hero__info {
    opacity: 0.78;
  }

  .photo-hero__overlay--bottom.is-quiet .photo-hero__info {
    transform: translateY(6px);
  }

  .photo-hero__specs {
    margin-top: 0.7rem;
    display: grid;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: rgba(245, 247, 250, 0.92);
  }

  .photo-hero__specs p {
    margin: 0;
    display: grid;
    gap: 0.16rem;
  }

  .photo-hero__specs span {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.62);
  }

  .photo-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.95rem;
  }

  .photo-hero__tags span {
    font-size: 0.74rem;
    color: rgba(232, 238, 243, 0.78);
  }

  .photo-gallery {
    padding: 2.5rem 0 5rem;
  }

  .photo-rail {
    position: relative;
    z-index: 3;
    width: min(100%, 100rem);
    margin: 0 auto;
    padding: 1.25rem clamp(1rem, 3vw, 2rem) 0;
  }

  .photo-rail__inner {
    display: flex;
