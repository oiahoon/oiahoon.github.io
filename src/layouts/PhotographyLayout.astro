</style>

<script>
  const galleryRoot = document.querySelector('.photo-page');
  const photoRailLinks = Array.from(document.querySelectorAll('[data-photo-link]'));
  const workLinks = Array.from(document.querySelectorAll('[data-work-link]'));
  const photoPanels = Array.from(document.querySelectorAll('[data-photo-panel]'));
  const lightbox = document.querySelector('[data-photo-lightbox]');
  const lightboxImage = lightbox?.querySelector('[data-lightbox-image]');
  const lightboxCaption = lightbox?.querySelector('[data-lightbox-caption]');
  const lightboxCounter = lightbox?.querySelector('[data-lightbox-counter]');
  const lightboxClose = lightbox?.querySelector('[data-lightbox-close]');
  const lightboxPrev = lightbox?.querySelector('[data-lightbox-prev]');
  const lightboxNext = lightbox?.querySelector('[data-lightbox-next]');
  const lightboxThumbs = lightbox?.querySelector('[data-lightbox-thumbs]');
  const lightboxTriggers = Array.from(document.querySelectorAll('[data-open-lightbox]'));
  const galleryData = galleryRoot?.getAttribute('data-photo-gallery');
  const photos = galleryData ? JSON.parse(galleryData) : [];
  const topbar = document.querySelector('.photo-topbar');
  const heroTopOverlay = document.querySelector('[data-photo-overlay-top]');
  const heroBottomOverlay = document.querySelector('[data-photo-overlay-bottom]');
  const controller = new AbortController();
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const scrollBehavior = reduceMotion.matches ? 'auto' : 'smooth';
  let lightboxCloseTimer = 0;
  let activePhoto = 1;
  let lightboxIndex = 0;
  let touchStartX = 0;
  let touchDeltaX = 0;
  let lightboxScale = 1;
  let panX = 0;
  let panY = 0;
  let panStartX = 0;
  let panStartY = 0;
  let isPanning = false;
  let lightboxReturnFocus = null;
  let observer = null;

  function applyLightboxTransform() {
    if (!lightboxImage) return;
    lightboxImage.style.transform = `translate(${panX}px, ${panY}px) scale(${lightboxScale})`;
    lightboxImage.style.cursor = lightboxScale > 1 ? (isPanning ? 'grabbing' : 'grab') : 'zoom-in';
  }

  function resetLightboxTransform() {
    lightboxScale = 1;
    panX = 0;
    panY = 0;
    isPanning = false;
    applyLightboxTransform();
  }

  function syncActiveRail(index) {
    activePhoto = index;
    photoRailLinks.forEach((link) => {
      link.classList.toggle('is-active', Number(link.getAttribute('data-photo-target')) === index);
    });
    const activeRailLink = photoRailLinks.find((link) => Number(link.getAttribute('data-photo-target')) === index);
    activeRailLink?.scrollIntoView({ behavior: scrollBehavior, block: 'nearest', inline: 'center' });
  }

  if (photoPanels.length && photoRailLinks.length) {
    observer = new IntersectionObserver((entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

      if (!visible) return;
      const index = Number(visible.target.getAttribute('data-photo-index'));
      if (index) syncActiveRail(index);
    }, { threshold: [0.35, 0.6], rootMargin: '-12% 0px -20% 0px' });

    photoPanels.forEach((panel) => observer.observe(panel));
    syncActiveRail(1);
  }

  const activeWorkLink = workLinks.find((link) => link.classList.contains('is-active'));
  activeWorkLink?.scrollIntoView({ behavior: scrollBehavior, block: 'nearest', inline: 'center' });

  function renderLightbox() {
    if (!photos[lightboxIndex] || !lightbox || !lightboxImage || !lightboxCaption || !lightboxCounter) return;
    const current = photos[lightboxIndex];
    lightboxImage.src = current.src;
    lightboxImage.alt = current.alt || '';
    lightboxCaption.textContent = current.caption || '';
    lightboxCounter.textContent = `照片 ${String(lightboxIndex + 1).padStart(2, '0')} / ${String(photos.length).padStart(2, '0')}`;
    resetLightboxTransform();
    if (lightboxThumbs) {
      lightboxThumbs.replaceChildren();
      photos.forEach((photo, index) => {
        const thumb = document.createElement('button');
        const image = document.createElement('img');
        thumb.type = 'button';
        thumb.className = `photo-lightbox__thumb ${index === lightboxIndex ? 'is-active' : ''}`;
        thumb.dataset.lightboxThumb = String(index);
        thumb.setAttribute('aria-label', `查看第 ${index + 1} 张照片`);
        image.src = photo.src;
        image.alt = photo.alt || `照片 ${index + 1}`;
        thumb.append(image);
        thumb.addEventListener('click', () => {
          lightboxIndex = index;
          renderLightbox();
        }, { signal: controller.signal });
        lightboxThumbs.append(thumb);
      });

      const activeThumb = lightboxThumbs.querySelector('.photo-lightbox__thumb.is-active');
      activeThumb?.scrollIntoView({ behavior: scrollBehavior, block: 'nearest', inline: 'center' });
    }
  }

  function lockPageScroll() {
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
  }

  function unlockPageScroll() {
    document.documentElement.style.overflow = '';
    document.body.style.overflow = '';
  }

  function focusableLightboxControls() {
    if (!lightbox) return [];
    return Array.from(lightbox.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'))
      .filter((node) => node instanceof HTMLElement && !node.hasAttribute('disabled') && !node.hidden);
  }

  function trapLightboxFocus(event) {
    if (event.key !== 'Tab' || !lightbox || lightbox.hidden) return;
    const focusable = focusableLightboxControls();
    if (!focusable.length) {
      event.preventDefault();
      lightbox.focus();
      return;
    }

    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  }

  function openLightbox(index) {
    if (!lightbox || !photos.length) return;
    lightboxReturnFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    window.clearTimeout(lightboxCloseTimer);
    lightboxIndex = Math.min(Math.max(index, 0), photos.length - 1);
    renderLightbox();
    lightbox.hidden = false;
    lightbox.setAttribute('aria-hidden', 'false');
    lockPageScroll();
    requestAnimationFrame(() => {
      lightbox.classList.add('is-open');
      lightboxClose?.focus?.();
    });
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    unlockPageScroll();
    resetLightboxTransform();
    window.clearTimeout(lightboxCloseTimer);
    lightboxCloseTimer = window.setTimeout(() => {
      if (!lightbox?.classList.contains('is-open')) {
        lightbox.hidden = true;
        lightboxReturnFocus?.focus?.({ preventScroll: true });
        lightboxReturnFocus = null;
      }
    }, 240);
  }

  function stepLightbox(direction) {
    if (!photos.length) return;
    lightboxIndex = (lightboxIndex + direction + photos.length) % photos.length;
    renderLightbox();
  }

  lightboxTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const index = Number(trigger.getAttribute('data-photo-index') || '1') - 1;
      openLightbox(index);
    }, { signal: controller.signal });
  });

  lightboxClose?.addEventListener('click', closeLightbox, { signal: controller.signal });
  lightboxPrev?.addEventListener('click', () => stepLightbox(-1), { signal: controller.signal });
  lightboxNext?.addEventListener('click', () => stepLightbox(1), { signal: controller.signal });
  lightboxImage?.addEventListener('dblclick', () => {
    if (lightboxScale > 1) {
      resetLightboxTransform();
      return;
    }
    lightboxScale = 2;
    applyLightboxTransform();
  }, { signal: controller.signal });
  lightboxImage?.addEventListener('pointerdown', (event) => {
    if (lightboxScale <= 1) return;
    isPanning = true;
    panStartX = event.clientX - panX;
    panStartY = event.clientY - panY;
    lightboxImage.setPointerCapture?.(event.pointerId);
    applyLightboxTransform();
  }, { signal: controller.signal });
  lightboxImage?.addEventListener('pointermove', (event) => {
    if (!isPanning || lightboxScale <= 1) return;
    panX = event.clientX - panStartX;
    panY = event.clientY - panStartY;
    applyLightboxTransform();
  }, { signal: controller.signal });
  lightboxImage?.addEventListener('pointerup', () => {
    isPanning = false;
    applyLightboxTransform();
  }, { signal: controller.signal });
  lightboxImage?.addEventListener('pointercancel', () => {
    isPanning = false;
    applyLightboxTransform();
  }, { signal: controller.signal });
  lightbox?.addEventListener('click', (event) => {
    if (event.target === lightbox) closeLightbox();
  }, { signal: controller.signal });
  lightbox?.addEventListener('touchstart', (event) => {
    touchStartX = event.changedTouches[0]?.clientX || 0;
    touchDeltaX = 0;
  }, { passive: true, signal: controller.signal });
  lightbox?.addEventListener('touchmove', (event) => {
    const currentX = event.changedTouches[0]?.clientX || 0;
    touchDeltaX = currentX - touchStartX;
  }, { passive: true, signal: controller.signal });
  lightbox?.addEventListener('touchend', () => {
    if (Math.abs(touchDeltaX) < 48) return;
    if (touchDeltaX > 0) stepLightbox(-1);
    if (touchDeltaX < 0) stepLightbox(1);
    touchStartX = 0;
    touchDeltaX = 0;
  }, { passive: true, signal: controller.signal });

  document.addEventListener('keydown', (event) => {
    const isOpen = lightbox && !lightbox.hidden;
    if (!isOpen) return;
    trapLightboxFocus(event);
    if (event.defaultPrevented) return;
    if (event.key === 'Escape') closeLightbox();
    if (event.key === 'ArrowLeft') stepLightbox(-1);
    if (event.key === 'ArrowRight') stepLightbox(1);
  }, { signal: controller.signal });

  function syncTopbarState() {
    if (!topbar) return;
    const quiet = window.scrollY > 120;
    topbar.classList.toggle('is-quiet', quiet);
    heroTopOverlay?.classList.toggle('is-quiet', quiet);
    heroBottomOverlay?.classList.toggle('is-quiet', quiet);
  }

  syncTopbarState();
  window.addEventListener('scroll', syncTopbarState, { passive: true, signal: controller.signal });
  document.addEventListener('astro:before-swap', () => {
    window.clearTimeout(lightboxCloseTimer);
    observer?.disconnect();
    unlockPageScroll();
    controller.abort();
  }, { once: true, signal: controller.signal });
</script>
