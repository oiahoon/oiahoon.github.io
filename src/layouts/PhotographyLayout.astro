---
import BaseLayout from './BaseLayout.astro';
import ProgressiveImage from '../components/ProgressiveImage.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  author: string;
  date: Date;
  tags: string[];
  header_img?: string;
  description?: string;
  lang: 'zh' | 'en';
  gallery?: Array<{ src: string; alt?: string; caption?: string; width?: number; height?: number }>;
  camera?: { model?: string; lens?: string; settings?: string };
  location?: string;
  publishedDate?: string;
}

const { title, subtitle, date, tags, header_img, description, lang, gallery, camera, location, publishedDate } = Astro.props;
const cover = header_img || gallery?.[0]?.src;
const heroPhoto = gallery?.[0];
const galleryPhotos = heroPhoto ? gallery.slice(1) : gallery ?? [];
const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();

const navigation = [
  { name: '文章', href: '/articles/' },
  { name: '摄影', href: '/photography/' },
  { name: '标签', href: '/tags/' },
  { name: '关于', href: '/about/' },
];
---

<BaseLayout title={`${title} | Joey's Notes`} description={description || subtitle || title} image={cover} lang={lang}>
  <article class="photo-page">
    <section class="photo-stage">
      <header class="photo-topbar">
        <div class="photo-topbar__inner">
          <a href="/" class="photo-topbar__brand">Joey's Notes</a>

          <nav class="photo-topbar__nav" aria-label="主导航">
            {navigation.map((item) => {
              const active = currentPath === item.href || (item.href === '/photography/' && currentPath.startsWith('/posts/'));
              return (
                <a href={item.href} class={`photo-topbar__link ${active ? 'is-active' : ''}`}>
                  {item.name}
                </a>
              );
            })}
          </nav>

          <button
            type="button"
            id="photo-theme-toggle"
            class="photo-topbar__toggle"
            aria-label="切换主题"
          >
            主题
          </button>
        </div>
      </header>

      {heroPhoto && (
        <section class="photo-hero">
          <div class="photo-hero__frame">
            <ProgressiveImage
              src={heroPhoto.src}
              alt={heroPhoto.alt || title || '摄影作品'}
              class="photo-hero__image"
              loading="eager"
              decoding="async"
            />
            <div class="photo-hero__veil"></div>
          </div>

          <div class="photo-hero__overlay photo-hero__overlay--top">
            <a href="/photography/" class="photo-hero__back">← 返回摄影列表</a>
          </div>

          <div class="photo-hero__overlay photo-hero__overlay--bottom">
            <div class="photo-hero__caption">
              <p class="photo-hero__date">
                {date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}
                {location ? ` · ${location}` : ''}
                {publishedDate ? ` · 发布于 ${publishedDate}` : ''}
              </p>
              {title && <h1 class="photo-hero__title">{title}</h1>}
              {subtitle && <p class="photo-hero__subtitle">{subtitle}</p>}
            </div>

            <div class="photo-hero__info" aria-label="拍摄信息">
              <p class="photo-hero__eyebrow">拍摄信息</p>
              <div class="photo-hero__specs">
                {camera?.model && <p><span>相机</span>{camera.model}</p>}
                {camera?.lens && <p><span>镜头</span>{camera.lens}</p>}
                {camera?.settings && <p><span>参数</span>{camera.settings}</p>}
                {!camera?.model && !camera?.lens && !camera?.settings && <p><span>信息</span>暂无拍摄参数</p>}
              </div>

              {tags.length > 0 && (
                <div class="photo-hero__tags">
                  {tags.map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        </section>
      )}

      {galleryPhotos.length > 0 && (
        <section class="photo-gallery">
          <div class="photo-gallery__stack">
            {galleryPhotos.map((photo, index) => (
              <figure class="photo-gallery__item">
                <div class="photo-gallery__frame">
                  <ProgressiveImage
                    src={photo.src}
                    alt={photo.alt || `Photo ${index + 2}`}
                    class="photo-gallery__image"
                    loading={index < 1 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </div>
                {photo.caption && <figcaption class="photo-gallery__caption">{photo.caption}</figcaption>}
              </figure>
            ))}
          </div>
        </section>
      )}

      <section class="photo-notes">
        <div class="photo-notes__body prose prose-lg">
          <slot />
        </div>
      </section>

      <footer class="photo-footer">
        <div class="photo-footer__inner">
          <div class="photo-footer__grid">
            <section>
              <p class="photo-footer__title">Joey's Notes</p>
              <p class="photo-footer__copy">记录软件工程实践与摄影观察，保持长期、可复用、可查阅的写作习惯。</p>
            </section>

            <section>
              <p class="photo-footer__title">导航</p>
              <div class="photo-footer__links">
                <a href="/articles/">文章</a>
                <a href="/photography/">摄影</a>
                <a href="/tags/">标签</a>
                <a href="/about/">关于</a>
              </div>
            </section>

            <section>
              <p class="photo-footer__title">订阅与链接</p>
              <div class="photo-footer__links">
                <a href="/rss.xml">RSS 订阅</a>
                <a href="https://github.com/oiahoon" target="_blank" rel="noopener noreferrer">GitHub</a>
                <a href="https://weibo.com/desiver" target="_blank" rel="noopener noreferrer">微博</a>
              </div>
            </section>
          </div>

          <div class="photo-footer__meta">© {year} Joey's Notes</div>
        </div>
      </footer>
    </section>
  </article>
</BaseLayout>

<style>
  .photo-page {
    min-height: 100vh;
    background: #05070b;
    color: #eef2f7;
  }

  .photo-stage {
    width: 100%;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.05), transparent 22%),
      linear-gradient(180deg, #05070b 0%, #070a10 58%, #080c12 100%);
  }

  .photo-topbar {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(4, 6, 10, 0.78);
    backdrop-filter: blur(10px);
  }

  .photo-topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(100%, 100rem);
    margin-inline: auto;
    padding: 1rem clamp(1rem, 3vw, 2rem);
  }

  .photo-topbar__brand {
    font-size: 1.05rem;
    font-weight: 600;
    color: rgba(248, 250, 252, 0.96);
  }

  .photo-topbar__nav {
    display: none;
    align-items: center;
    gap: 1.6rem;
  }

  .photo-topbar__link {
    position: relative;
    color: rgba(226, 232, 240, 0.7);
    font-size: 0.94rem;
    transition: color 0.2s ease;
  }

  .photo-topbar__link.is-active,
  .photo-topbar__link:hover {
    color: #f8fafc;
  }

  .photo-topbar__link.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.4rem;
    height: 1px;
    background: rgba(245, 158, 11, 0.8);
  }

  .photo-topbar__toggle {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 9999px;
    padding: 0.5rem 0.95rem;
    background: transparent;
    color: rgba(248, 250, 252, 0.9);
    font-size: 0.8rem;
    cursor: pointer;
  }

  .photo-hero {
    position: relative;
    min-height: calc(100vh - 4.4rem);
    background: #05070b;
  }

  .photo-hero__frame {
    position: relative;
    min-height: calc(100vh - 4.4rem);
  }

  .photo-hero__image {
    width: 100%;
    height: calc(100vh - 4.4rem);
    object-fit: cover;
    object-position: center;
  }

  .photo-hero__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(5, 7, 11, 0.52) 0%, rgba(5, 7, 11, 0.14) 22%, rgba(5, 7, 11, 0.06) 48%, rgba(5, 7, 11, 0.58) 100%),
      linear-gradient(90deg, rgba(5, 7, 11, 0.2) 0%, transparent 20%, transparent 78%, rgba(5, 7, 11, 0.18) 100%);
    pointer-events: none;
  }

  .photo-hero__overlay {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 2;
    width: min(100%, 100rem);
    margin-inline: auto;
    padding-inline: clamp(1rem, 3vw, 2rem);
  }

  .photo-hero__overlay--top {
    top: 1.35rem;
  }

  .photo-hero__overlay--bottom {
    bottom: 0;
    display: grid;
    gap: 1rem;
    align-items: end;
    padding-bottom: clamp(1.25rem, 3vw, 2rem);
  }

  .photo-hero__back {
    display: inline-flex;
    align-items: center;
    color: rgba(245, 247, 250, 0.92);
    font-size: 0.94rem;
    letter-spacing: 0.01em;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
  }

  .photo-hero__caption,
  .photo-hero__info {
    max-width: 100%;
    color: rgba(248, 250, 252, 0.94);
    text-shadow: 0 2px 22px rgba(0, 0, 0, 0.6);
  }

  .photo-hero__date {
    margin: 0;
    font-size: 0.84rem;
    letter-spacing: 0.04em;
    color: rgba(226, 232, 240, 0.78);
  }

  .photo-hero__title {
    margin: 0.65rem 0 0;
    font-size: clamp(2.3rem, 4.8vw, 5rem);
    line-height: 0.98;
    color: #f8fafc;
  }

  .photo-hero__subtitle {
    margin: 0.8rem 0 0;
    max-width: 38rem;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(230, 236, 242, 0.82);
  }

  .photo-hero__eyebrow {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.66);
  }

  .photo-hero__specs {
    margin-top: 0.7rem;
    display: grid;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: rgba(245, 247, 250, 0.92);
  }

  .photo-hero__specs p {
    margin: 0;
    display: grid;
    gap: 0.16rem;
  }

  .photo-hero__specs span {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(226, 232, 240, 0.62);
  }

  .photo-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.95rem;
  }

  .photo-hero__tags span {
    font-size: 0.74rem;
    color: rgba(232, 238, 243, 0.78);
  }

  .photo-gallery {
    padding: 2.5rem 0 5rem;
  }

  .photo-gallery__stack {
    display: grid;
    gap: 3rem;
    width: min(100%, 110rem);
    margin-inline: auto;
    padding-inline: clamp(0.75rem, 2vw, 1.5rem);
  }

  .photo-gallery__item {
    margin: 0;
  }

  .photo-gallery__frame {
    display: flex;
    min-height: min(90vh, 62rem);
    align-items: center;
    justify-content: center;
  }

  .photo-gallery__image {
    width: 100%;
    max-height: min(90vh, 62rem);
    object-fit: contain;
  }

  .photo-gallery__caption {
    width: min(46rem, calc(100% - 2rem));
    margin: 0.9rem auto 0;
    color: rgba(226, 232, 240, 0.62);
    text-align: center;
    font-size: 0.92rem;
    line-height: 1.8;
  }

  .photo-notes {
    padding: 0 0 5rem;
  }

  .photo-notes__body {
    width: min(46rem, calc(100% - 2rem));
    margin-inline: auto;
    color: rgba(236, 240, 244, 0.9);
  }

  .photo-notes__body :global(p),
  .photo-notes__body :global(li) {
    color: rgba(236, 240, 244, 0.78);
  }

  .photo-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: #070a10;
  }

  .photo-footer__inner {
    width: min(100%, 96rem);
    margin-inline: auto;
    padding: 3rem clamp(1rem, 3vw, 2rem) 2rem;
  }

  .photo-footer__grid {
    display: grid;
    gap: 2rem;
  }

  .photo-footer__title {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 600;
    color: rgba(248, 250, 252, 0.96);
  }

  .photo-footer__copy {
    max-width: 18rem;
    margin: 0.8rem 0 0;
    font-size: 0.92rem;
    line-height: 1.8;
    color: rgba(195, 203, 214, 0.72);
  }

  .photo-footer__links {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-top: 0.8rem;
  }

  .photo-footer__links a {
    color: rgba(195, 203, 214, 0.72);
    transition: color 0.2s ease;
  }

  .photo-footer__links a:hover {
    color: rgba(248, 250, 252, 0.94);
  }

  .photo-footer__meta {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.78rem;
    color: rgba(195, 203, 214, 0.58);
  }

  @media (min-width: 900px) {
    .photo-topbar__nav {
      display: flex;
    }

    .photo-hero__overlay--bottom {
      grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.72fr);
      gap: 2rem;
    }

    .photo-footer__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .photo-topbar__inner {
      gap: 0.75rem;
    }

    .photo-hero,
    .photo-hero__frame {
      min-height: calc(100svh - 4.4rem);
    }

    .photo-hero__image {
      height: calc(100svh - 4.4rem);
    }

    .photo-hero__overlay--top {
      top: 0.9rem;
    }

    .photo-hero__overlay--bottom {
      gap: 0.9rem;
      padding-bottom: 1rem;
    }

    .photo-hero__title {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .photo-hero__subtitle {
      font-size: 0.95rem;
      max-width: 26rem;
    }

    .photo-gallery {
      padding-top: 1.5rem;
    }

    .photo-gallery__frame {
      min-height: 56vh;
    }
  }
</style>

<script>
  const toggle = document.getElementById('photo-theme-toggle');
  toggle?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
  });
</script>
