---
import BaseLayout from './BaseLayout.astro';
import SpotlightHeader from '../components/SpotlightHeader.astro';
import SpotlightFooter from '../components/SpotlightFooter.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: 'zh' | 'en';
  structuredData?: string;
}

const props = Astro.props;
const lang = props.lang ?? 'zh';
const isPhotoArchive = Astro.url.pathname === '/photography/';
const skipLabel = lang === 'zh' ? '跳到主要内容' : 'Skip to main content';
---

<BaseLayout {...props} themeMode={isPhotoArchive ? 'locked-dark' : 'system'}>
  <div class={`min-h-screen w-full ${isPhotoArchive ? 'spotlight-layout--photo' : ''}`}>
    <a class="skip-link" href="#main-content">{skipLabel}</a>
    <SpotlightHeader lang={lang} />
    <main id="main-content" class={isPhotoArchive ? 'pb-0' : 'pb-24'}>
      <slot />
    </main>
    <SpotlightFooter lang={lang} />
  </div>
</BaseLayout>

<style>
  .spotlight-layout--photo {
    background: linear-gradient(180deg, #05070b 0%, #070a10 72%, #080c12 100%);
  }
</style>
