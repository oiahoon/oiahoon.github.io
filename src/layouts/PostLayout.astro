---
import SpotlightLayout from './SpotlightLayout.astro';
import PhotographyLayout from './PhotographyLayout.astro';
import { generateBlogPostStructuredData } from '../utils/seo';
import UiIcon from '../components/UiIcon.astro';

export interface Props {
  title: string;
  subtitle?: string;
  author: string;
  date: Date;
  slug?: string;
  tags: string[];
  header_img?: string;
  description?: string;
  lang: 'zh' | 'en';
  type?: 'article' | 'photography';
  gallery?: Array<{ src: string; alt?: string; caption?: string; width?: number; height?: number }>;
  camera?: { model?: string; lens?: string; settings?: string };
  location?: string;
  publishedDate?: string;
  previousPhoto?: { slug: string; title?: string; date: Date; image?: string };
  nextPhoto?: { slug: string; title?: string; date: Date; image?: string };
  photoCollection?: Array<{ slug: string; title?: string; date: Date; image?: string; active?: boolean }>;
}

const { title, subtitle, author, date, slug, tags, header_img, description, lang, type = 'article', gallery, camera, location, publishedDate, previousPhoto, nextPhoto, photoCollection } = Astro.props;
const fallbackTitle = title || (type === 'photography'
  ? `摄影作品 · ${date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}`
  : '文章');

const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
const previewImage = header_img || (type === 'photography' && gallery?.[0]?.src);
const structuredData = generateBlogPostStructuredData({
  title: fallbackTitle,
  description: description || subtitle || fallbackTitle,
  author,
  date,
  image: previewImage,
  url: postUrl,
  tags,
  type,
});
---

{type === 'photography' ? (
  <PhotographyLayout
    title={title}
    subtitle={subtitle}
    author={author}
    date={date}
    slug={slug}
    tags={tags}
    header_img={header_img}
    description={description}
    lang={lang}
    gallery={gallery}
    camera={camera}
    location={location}
    publishedDate={publishedDate}
    previousPhoto={previousPhoto}
    nextPhoto={nextPhoto}
    photoCollection={photoCollection}
  >
    <slot />
  </PhotographyLayout>
) : (
  <SpotlightLayout title={`${fallbackTitle} | Joey's Notes`} description={description || subtitle || fallbackTitle} image={previewImage || undefined} lang={lang} structuredData={structuredData}>
    <article class="section-gap">
      <div class="shell">
        <div class="reading-narrow">
          <a href="/articles/" class="article-back-link text-sm muted hover:text-[var(--text)]" data-astro-prefetch><UiIcon name="arrowLeft" size={14} /> <span>返回文章列表</span></a>

          <header class="mt-8 border-b pb-10" style="border-color: var(--line);">
            <p class="entry-meta skeleton-text">
              <UiIcon name="calendar" size={13} />
              <span>
                {date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
                · {author}
              </span>
            </p>
            <h1
              class="mt-4 text-4xl font-semibold leading-[1.15] sm:text-5xl skeleton-text"
              style={slug ? `view-transition-name: article-title-${slug};` : undefined}
            >
              {title}
            </h1>
            {subtitle && <p class="mt-5 text-lg leading-8 muted skeleton-text">{subtitle}</p>}
          </header>

          <div class="text-skeleton-stack" aria-hidden="true">
            <span />
            <span />
            <span />
            <span />
            <span />
            <span />
            <span />
            <span />
          </div>

          <div class="prose prose-lg mt-12 text-content-block">
            <slot />
          </div>

          {tags.length > 0 && (
            <footer class="mt-14 border-t pt-6" style="border-color: var(--line);">
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <a href={`/tags/${encodeURIComponent(tag)}/`} class="article-tag-pill rounded-full border px-2.5 py-1 text-xs muted hover:text-[var(--text)]" style="border-color: var(--line);" data-astro-prefetch>
                    <UiIcon name="tag" size={12} />
                    <span>{tag}</span>
                  </a>
                ))}
              </div>
            </footer>
          )}

          <div class="mt-8 flex items-center justify-between border-t pt-6 text-sm" style="border-color: var(--line);">
            <a href="/articles/" class="article-back-link muted hover:text-[var(--text)]" data-astro-prefetch><UiIcon name="article" size={14} /> <span>返回文章列表</span></a>
            <a href="/tags/" class="article-back-link muted hover:text-[var(--text)]" data-astro-prefetch><UiIcon name="tag" size={14} /> <span>浏览全部标签</span></a>
          </div>
        </div>
      </div>
    </article>
    <style>
    .article-back-link,
    .article-tag-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    .article-back-link :global(.ui-icon),
    .article-tag-pill :global(.ui-icon) {
      color: color-mix(in srgb, var(--accent) 64%, var(--muted));
      opacity: 0.68;
    }
  </style>
</SpotlightLayout>
)}
